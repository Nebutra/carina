{
  "name": "carina-vscode",
  "displayName": "Carina Agent Runtime",
  "version": "0.6.2",
  "publisher": "nebutra",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/Nebutra/carina.git" },
  "private": true,
  "engines": { "vscode": "^1.95.0" },
  "main": "./dist/extension.js",
  "files": ["dist/**", "media/**", "README.md", "LICENSE"],
  "activationEvents": ["onView:carina.agents", "onCommand:carina.refresh"],
  "contributes": {
    "viewsContainers": { "activitybar": [{ "id": "carina", "title": "Carina", "icon": "media/carina.svg" }] },
    "views": { "carina": [{ "id": "carina.agents", "name": "Agent View" }] },
    "commands": [
      { "command": "carina.refresh", "title": "Carina: Refresh Agent View" },
      { "command": "carina.inspect", "title": "Carina: Inspect Session" },
      { "command": "carina.attach", "title": "Carina: Attach Session" },
      { "command": "carina.steer", "title": "Carina: Steer Task" },
      { "command": "carina.approve", "title": "Carina: Resolve Approval" },
      { "command": "carina.answer", "title": "Carina: Answer Question" },
      { "command": "carina.previewPatch", "title": "Carina: Preview Patch" },
      { "command": "carina.openArtifact", "title": "Carina: Open Artifact" }
    ],
    "menus": {
      "view/title": [{ "command": "carina.refresh", "when": "view == carina.agents", "group": "navigation" }],
      "view/item/context": [
        { "command": "carina.inspect", "when": "view == carina.agents && viewItem =~ /carinaAgent/", "group": "inline" },
        { "command": "carina.steer", "when": "viewItem == carinaAgent.working", "group": "carina@1" },
        { "command": "carina.approve", "when": "viewItem == carinaAgent.needs_input", "group": "carina@2" },
        { "command": "carina.answer", "when": "viewItem == carinaAgent.needs_input", "group": "carina@3" },
        { "command": "carina.previewPatch", "when": "view == carina.agents && viewItem =~ /carinaAgent/", "group": "carina@4" }
      ]
    },
    "configuration": {
      "title": "Carina",
      "properties": {
        "carina.socketPath": { "type": "string", "default": "", "description": "Daemon Unix socket; empty uses ~/.carina/daemon.sock." },
        "carina.refreshIntervalMs": { "type": "number", "default": 3000, "minimum": 1000 }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "npm run build && node --test test/*.test.mjs",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "3.9.2",
    "typescript": "^5.7.0"
  }
}
