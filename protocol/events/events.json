{
  "$comment": "Canonical event type enumeration (PRD §8.2). The event log is append-only; every event carries timestamp + session_id; side-effect events carry permission_decision_id.",
  "version": "0.4.0",
  "types": [
    { "name": "TaskCreated", "side_effect": false, "payload": ["task_id", "user_prompt"] },
    { "name": "ModelRequested", "side_effect": false, "payload": ["provider", "model", "input_tokens"] },
    { "name": "ModelResponded", "side_effect": false, "payload": ["provider", "model", "output_tokens", "stop_reason"] },
    { "name": "RoutingDecision", "side_effect": false, "payload": ["evidence_id", "requested_model", "reasoner", "policy", "prompt_sha256", "input_tokens_estimated"] },
    { "name": "RoutingOutcome", "side_effect": false, "payload": ["evidence_id", "requested_model", "status", "latency_ms", "prompt_sha256", "response_sha256", "output_tokens_estimated"] },
    { "name": "RoutingRetryScheduled", "side_effect": false, "payload": ["evidence_id", "attempt", "max_attempts", "error"] },
    { "name": "ContextCompacted", "side_effect": false, "payload": ["receipt"] },
    { "name": "MemoryRecalled", "side_effect": false, "payload": ["provider", "mode", "status", "reason", "evidence_count", "adapter_version"] },
    { "name": "MemoryRecallRequested", "side_effect": false, "payload": ["provider", "endpoint_host", "query_sha256", "status"] },
    { "name": "MemoryWriteRequested", "side_effect": false, "payload": ["target", "action", "content_sha256", "status"] },
    { "name": "MemoryWritten", "side_effect": true, "payload": ["target", "revision", "parent_revision", "status"] },
    { "name": "MemoryProjectionChanged", "side_effect": false, "payload": ["provider", "status", "reason", "target", "document_id", "revision", "generation"] },
    { "name": "MemoryProjected", "side_effect": true, "payload": ["provider", "status", "reason", "target", "document_id", "revision", "generation"] },
    { "name": "ScheduleChanged", "side_effect": false, "payload": ["action", "schedule_id"] },
    { "name": "ScheduleTriggered", "side_effect": false, "payload": ["schedule_id", "status"] },
    { "name": "GoalChangeRequested", "side_effect": false, "payload": ["action", "from_status", "to_status", "status"] },
    { "name": "GoalChanged", "side_effect": false, "payload": ["action", "status", "tokens_used", "token_budget", "continuations_used", "max_continuations"] },
    { "name": "ToolRequested", "side_effect": false, "payload": ["tool", "arguments"] },
    { "name": "ToolApproved", "side_effect": false, "payload": ["tool", "decision_id"] },
    { "name": "ToolDenied", "side_effect": false, "payload": ["tool", "decision_id", "reason"] },
    { "name": "ToolCallRequested", "side_effect": false, "payload": ["call_id", "tool", "kind", "status", "arguments"] },
    { "name": "ToolCallApprovalRequired", "side_effect": false, "payload": ["call_id", "tool", "kind", "status", "decision_id"] },
    { "name": "ToolCallStarted", "side_effect": false, "payload": ["call_id", "tool", "kind", "status"] },
    { "name": "ToolCallCompleted", "side_effect": false, "payload": ["call_id", "tool", "kind", "status", "output", "artifact_ids"] },
    { "name": "ToolCallFailed", "side_effect": false, "payload": ["call_id", "tool", "kind", "status", "error"] },
    { "name": "ToolCallDenied", "side_effect": false, "payload": ["call_id", "tool", "kind", "status", "error"] },
    { "name": "ToolCallCancelled", "side_effect": false, "payload": ["call_id", "tool", "kind", "status", "error"] },
    { "name": "RuntimeStageChanged", "side_effect": false, "payload": ["stage_id", "stage", "status", "sequence", "call_id"] },
    { "name": "FileRead", "side_effect": true, "payload": ["path", "bytes"] },
    { "name": "FileWriteProposed", "side_effect": false, "payload": ["path", "patch_id"] },
    { "name": "PatchProposed", "side_effect": false, "payload": ["patch_id", "affected_files", "reason"] },
    { "name": "PatchApplied", "side_effect": true, "payload": ["patch_id", "new_hash", "rollback_pointer"] },
    { "name": "PatchFailed", "side_effect": false, "payload": ["patch_id", "error"] },
    { "name": "CommandStarted", "side_effect": true, "payload": ["command", "cwd", "risk_level"] },
    { "name": "CommandOutput", "side_effect": false, "payload": ["stream", "chunk"] },
    { "name": "CommandExited", "side_effect": false, "payload": ["exit_code", "duration_ms"] },
    { "name": "NetworkRequested", "side_effect": true, "payload": ["host", "method"] },
    { "name": "SecretRequested", "side_effect": true, "payload": ["secret_handle"] },
    { "name": "PolicyViolation", "side_effect": false, "payload": ["capability", "resource", "policy_id"] },
    { "name": "RollbackStarted", "side_effect": true, "payload": ["patch_id", "rollback_pointer"] },
    { "name": "RollbackCompleted", "side_effect": false, "payload": ["patch_id"] },
    { "name": "SessionPaused", "side_effect": false, "payload": ["reason"] },
    { "name": "SessionResumed", "side_effect": false, "payload": ["reason"] },
    { "name": "SessionClosed", "side_effect": false, "payload": ["reason"] }
  ]
}
