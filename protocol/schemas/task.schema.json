{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Nebutra/carina/protocol/schemas/task.schema.json",
  "title": "Task",
  "type": "object",
  "required": ["task_id", "session_id", "workspace_id", "status", "user_prompt", "created_at", "updated_at"],
  "properties": {
    "task_id": { "type": "string", "pattern": "^task_" },
    "client_submission_id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$" },
    "session_id": { "type": "string", "pattern": "^sess_" },
    "workspace_id": { "type": "string", "pattern": "^ws_" },
    "status": { "enum": ["queued", "running", "paused", "waiting_approval", "interrupted", "completed", "degraded", "failed", "cancelled"] },
    "revision": { "type": "integer", "minimum": 1 },
    "continuity": {
      "type": "object",
      "required": ["activity", "outcome", "progress", "recovery"],
      "properties": {
        "activity": { "enum": ["running", "waiting_input", "waiting_approval", "idle"] },
        "outcome": { "enum": ["none", "completed", "partial", "failed", "cancelled", "interrupted"] },
        "progress": { "enum": ["empty", "started", "in_progress", "verifying", "partially_complete", "complete"] },
        "recovery": {
          "type": "object",
          "required": ["disposition"],
          "properties": {
            "disposition": { "enum": ["none", "continue", "retry", "resume_checkpoint", "review_required", "blocked"] },
            "reason": { "type": "string" },
            "checkpoint_id": { "type": "string" },
            "recovery_generation": { "type": "integer", "minimum": 0 },
            "proofs": { "type": "object", "additionalProperties": { "type": "boolean" } }
          }
        },
        "interruption": { "type": "object" },
        "execution": { "type": "object" },
        "workspace_anchor": { "type": "object" },
        "recovery_generation": { "type": "integer", "minimum": 0 },
        "auto_recovery_attempts": { "type": "integer", "minimum": 0 }
      }
    },
    "user_prompt": { "type": "string" },
	"input_media_refs": {
	  "type": "array",
	  "maxItems": 4,
	  "items": {
		"type": "object",
		"required": ["artifact_id", "media_type", "bytes"],
		"properties": {
		  "artifact_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
		  "media_type": { "enum": ["image/png", "image/jpeg", "image/gif", "image/webp"] },
		  "bytes": { "type": "integer", "minimum": 1, "maximum": 4194304 },
		  "origin": { "type": "string" }
		},
		"additionalProperties": false
	  }
	},
    "model": { "type": "string" },
    "requested_model": { "type": "string" },
    "effective_model": { "type": "string" },
    "requested_reasoning_effort": { "type": "string" },
    "effective_reasoning_effort": { "type": "string" },
    "agent": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "risk_level": { "type": "integer", "minimum": 0, "maximum": 5 },
    "mode": { "enum": ["foreground", "background", "dispatch"] },
    "tokens_used": { "type": "integer", "minimum": 0 },
    "token_usage_observed": { "type": "boolean" },
    "lease_owner": { "type": "string", "minLength": 1 },
    "lease_expiry": { "type": "string", "format": "date-time" },
    "lease_generation": { "type": "integer", "minimum": 1 },
    "attempts": { "type": "integer", "minimum": 0 }
  }
}
