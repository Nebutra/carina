{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Nebutra/carina/protocol/schemas/event.schema.json",
  "title": "Event",
  "description": "Append-only audit event. Side-effect events MUST carry permission_decision_id.",
  "type": "object",
  "required": [
    "event_id",
    "session_id",
    "type",
    "timestamp"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt_"
    },
    "session_id": {
      "type": "string",
      "pattern": "^sess_"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_"
    },
    "type": {
      "enum": [
        "TaskCreated",
        "ModelRequested",
        "ModelResponded",
        "ToolRequested",
        "ToolApproved",
        "ToolDenied",
        "FileRead",
        "FileWriteProposed",
        "PatchProposed",
        "PatchApplied",
        "PatchFailed",
        "CommandStarted",
        "CommandOutput",
        "CommandExited",
        "NetworkRequested",
        "SecretRequested",
        "PolicyViolation",
        "RollbackStarted",
        "RollbackCompleted",
        "SessionClosed"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    },
    "permission_decision_id": {
      "type": "string",
      "pattern": "^perm_"
    },
    "actor": {
      "enum": [
        "go",
        "rust",
        "zig",
        "model",
        "user",
        "agent",
        "plugin"
      ],
      "description": "language layer that produced the event"
    },
    "prev_hash": {
      "type": "string",
      "description": "hash of the previous event in the session chain"
    },
    "event_hash": {
      "type": "string",
      "description": "sha256(prev_hash || canonical(event)); tamper-evident chain"
    }
  }
}
