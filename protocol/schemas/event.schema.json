{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Nebutra/carina/protocol/schemas/event.schema.json",
  "title": "Event",
  "description": "Append-only audit event. Side-effect events MUST carry permission_decision_id.",
  "type": "object",
  "required": [
    "event_id",
    "session_id",
    "type",
    "timestamp"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt_"
    },
    "session_id": {
      "type": "string",
      "pattern": "^sess_"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_"
    },
    "type": {
      "enum": [
        "TaskCreated",
        "ModelRequested",
        "ModelResponded",
        "RoutingDecision",
        "RoutingOutcome",
        "RoutingRetryScheduled",
        "ContextCompacted",
        "MemoryRecalled",
        "MemoryProjectionChanged",
        "MemoryProjected",
        "ScheduleChanged",
        "ScheduleTriggered",
        "ToolRequested",
        "ToolApproved",
        "ToolDenied",
        "ToolCallRequested",
        "ToolCallApprovalRequired",
        "ToolCallStarted",
        "ToolCallCompleted",
        "ToolCallFailed",
        "ToolCallDenied",
        "ToolCallCancelled",
        "RuntimeStageChanged",
        "FileRead",
        "FileWriteProposed",
        "PatchProposed",
        "PatchApplied",
        "PatchFailed",
        "CommandStarted",
        "CommandOutput",
        "CommandExited",
        "NetworkRequested",
        "SecretRequested",
        "PolicyViolation",
        "RollbackStarted",
        "RollbackCompleted",
        "SessionPaused",
        "SessionResumed",
        "SessionClosed"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    },
    "permission_decision_id": {
      "type": "string",
      "pattern": "^perm_"
    },
    "actor": {
      "enum": [
        "go",
        "rust",
        "zig",
        "model",
        "user",
        "agent",
        "plugin",
        "operator",
        "worker"
      ],
      "description": "language layer that produced the event"
    },
    "prev_hash": {
      "type": "string",
      "description": "hash of the previous event in the session chain"
    },
    "event_hash": {
      "type": "string",
      "description": "sha256(prev_hash || canonical(event)); tamper-evident chain"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "RoutingRetryScheduled" } }, "required": ["type"] },
      "then": { "required": ["payload"], "properties": { "payload": { "required": ["evidence_id", "attempt", "max_attempts", "error"], "properties": { "attempt": { "type": "integer", "minimum": 1 }, "max_attempts": { "type": "integer", "minimum": 1 }, "error": { "type": "object", "required": ["code", "category", "message", "retry"] } } } } }
    },
    {
      "if": { "properties": { "type": { "const": "ToolCallApprovalRequired" } }, "required": ["type"] },
      "then": { "required": ["payload"], "properties": { "payload": { "required": ["call_id", "tool", "kind", "status", "decision_id"], "properties": { "status": { "const": "awaiting_approval" }, "decision_id": { "type": "string", "pattern": "^perm_" } } } } }
    },
    {
      "if": { "properties": { "type": { "const": "ToolCallRequested" } }, "required": ["type"] },
      "then": { "required": ["payload"], "properties": { "payload": { "required": ["call_id", "tool", "kind", "status", "arguments"], "properties": { "status": { "const": "pending" }, "arguments": { "type": "object" } } } } }
    },
    {
      "if": { "properties": { "type": { "const": "ToolCallStarted" } }, "required": ["type"] },
      "then": { "required": ["payload"], "properties": { "payload": { "required": ["call_id", "tool", "kind", "status"], "properties": { "status": { "const": "running" } } } } }
    },
    {
      "if": { "properties": { "type": { "enum": ["ToolCallCompleted", "ToolCallFailed", "ToolCallDenied", "ToolCallCancelled"] } }, "required": ["type"] },
      "then": { "required": ["payload"], "properties": { "payload": { "required": ["call_id", "tool", "kind", "status"], "not": { "required": ["output_preview"] } } } }
    },
    {
      "if": { "properties": { "type": { "const": "ToolCallCompleted" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "required": ["output", "artifact_ids"], "properties": { "status": { "const": "completed" }, "output": { "type": "object", "required": ["sha256", "bytes", "redacted", "artifact_status"], "properties": { "artifact_status": { "enum": ["available", "unavailable", "not_created"] } } }, "artifact_ids": { "type": "array", "items": { "type": "string", "pattern": "^[0-9a-f]{64}$" } } } } } }
    },
    {
      "if": { "properties": { "type": { "enum": ["ToolCallFailed", "ToolCallDenied", "ToolCallCancelled"] } }, "required": ["type"] },
      "then": { "properties": { "payload": { "required": ["error"], "properties": { "error": { "type": "object", "required": ["code", "category", "message"] } } } } }
    },
    {
      "if": { "properties": { "type": { "const": "RuntimeStageChanged" } }, "required": ["type"] },
      "then": { "required": ["payload"], "properties": { "payload": { "required": ["stage_id", "stage", "status", "sequence", "call_id"] } } }
    }
  ]
}
