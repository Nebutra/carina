      { "method": "runtime.capabilities", "scope": "read", "remote": true, "params": {}, "result": "{ runtime_version: semver, protocol_version: semver, capabilities: object }" },
      { "method": "runtime.registry_schema", "scope": "read", "remote": true, "params": {}, "result": "JSON Schema Draft 2020-12" }
    ],
