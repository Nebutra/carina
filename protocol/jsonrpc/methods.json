      { "method": "daemon.remote.disable", "scope": "admin", "remote": false, "control_plane_write": true, "params": { "on": "boolean" }, "result": "{ remote_disabled: boolean }" },
      { "method": "daemon.reload", "scope": "admin", "remote": false, "control_plane_write": true, "params": {}, "result": "{ reloaded: boolean }" }
