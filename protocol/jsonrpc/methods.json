{
  "$comment": "Carina JSON-RPC 2.0 method registry (MVP draft). Transport: unix socket (~/.carina/daemon.sock) or stdio, newline-delimited JSON. Server->client notifications use method 'event' with an Event payload (see ../schemas/event.schema.json).",
  "version": "0.1.0",
  "apis": {
    "gateway": [
      { "method": "gateway.hello", "params": { "protocol_version": "number?", "client_id": "string?", "role": "operator|observer|worker|node?", "scopes": "Scope[]?", "token": "string?" }, "result": "GatewayHello" },
      { "method": "gateway.methods", "params": {}, "result": { "version": "string", "methods": "MethodDescriptor[]" } },
      { "method": "gateway.resolve_scope", "params": { "method": "string", "params": "object?" }, "result": { "method": "string", "scope": "Scope", "dynamic_scope": "boolean" } },
      { "method": "gateway.token.issue", "params": { "subject": "string?", "role": "operator|observer|worker|node?", "scopes": "Scope[]", "routes": "string[]?", "ttl_seconds": "number?", "transport": "ws|http|plugin?" }, "result": { "token": "string", "claims": "GatewayTokenClaims" }, "availability": "local-only; registered only when gateway_token_signing_key_file is configured" }
    ],
    "session": [
      { "method": "session.create", "params": { "workspace_root": "string", "profile": "string" }, "result": "Session" },
      { "method": "session.get", "params": { "session_id": "string" }, "result": "Session" },
      { "method": "session.list", "params": {}, "result": "Session[]" },
      { "method": "session.pause", "params": { "session_id": "string" }, "result": "Session" },
      { "method": "session.resume", "params": { "session_id": "string" }, "result": "Session" },
      { "method": "session.close", "params": { "session_id": "string" }, "result": "Session" },
      { "method": "session.export", "params": { "session_id": "string", "format": "jsonl|sqlite" }, "result": { "path": "string" } },
      { "method": "session.replay", "params": { "session_id": "string" }, "result": "Event[]" },
      { "method": "session.items", "params": { "session_id": "string" }, "result": "SessionItemEvent[]" }
    ],
    "memory": [
      { "method": "memory.list", "params": { "session_id": "string", "target": "memory|user?" }, "result": "MemoryState", "availability": "local-only" },
      { "method": "memory.context", "params": { "session_id": "string" }, "result": { "scope": "MemoryScope", "context": "string" }, "availability": "local-only" },
      { "method": "memory.search", "params": { "session_id": "string", "query": "string", "target": "memory|user?", "limit": "number?" }, "result": "MemorySearchResult", "availability": "local-only; curated entries only" },
      { "method": "memory.write", "params": { "session_id": "string", "target": "memory|user?", "action": "add|replace|remove|batch", "content": "string?", "old_text": "string?", "operations": "MemoryOperation[]?" }, "result": "{ decision: PermissionDecision, result?: MemoryWriteResult }", "availability": "local-only; control-plane write; MemoryWrite capability-gated" }
    ],
    "schedule": [
      { "method": "schedule.create", "params": { "session_id": "string", "prompt": "string", "kind": "at|every|cron", "expression": "string" }, "result": "Schedule", "availability": "local-only; control-plane write" },
      { "method": "schedule.list", "params": {}, "result": "{ schedules: Schedule[] }", "availability": "local-only" },
      { "method": "schedule.pause", "params": { "schedule_id": "string" }, "result": "Schedule", "availability": "local-only; control-plane write" },
      { "method": "schedule.resume", "params": { "schedule_id": "string" }, "result": "Schedule", "availability": "local-only; control-plane write" },
      { "method": "schedule.delete", "params": { "schedule_id": "string" }, "result": "{ deleted: boolean, schedule_id: string }", "availability": "local-only; control-plane write" }
    ],
    "context": [
      { "method": "context.status", "params": {}, "result": "ContextEngineStatus", "availability": "local-only" },
      { "method": "context.doctor", "params": {}, "result": "{ ok: boolean, status: ContextEngineStatus }", "availability": "local-only" },
      { "method": "context.stats", "params": {}, "result": "{ local: ContextEngineStats, headroom?: object, headroom_error?: string }", "availability": "local-only" },
      { "method": "context.compress", "params": { "content": "string", "session_id": "string?", "task_id": "string?", "turn": "number?", "kind": "string?", "tool": "string?", "pinned": "boolean?" }, "result": "ContextCompressResponse", "availability": "local-only diagnostic/write surface" },
      { "method": "context.retrieve", "params": { "hash": "string?", "ref": "string?", "query": "string?" }, "result": "ContextRetrieveResponse", "availability": "local-only diagnostic surface; not remote-exposed" }
    ],
    "task": [
      { "method": "task.submit", "params": { "session_id": "string", "prompt": "string" }, "result": "Task" },
      { "method": "task.cancel", "params": { "task_id": "string" }, "result": "Task" },
      { "method": "task.status", "params": { "task_id": "string" }, "result": "Task" },
      { "method": "task.events.stream", "params": { "task_id": "string" }, "result": "subscription" },
      { "method": "task.action.approve", "params": { "session_id": "string", "decision_id": "string", "approver": "string?", "role": "string?" }, "result": "{ decision: PermissionDecision, result?: any }" },
      { "method": "task.action.deny", "params": { "session_id": "string", "decision_id": "string", "approver": "string?", "reason": "string" }, "result": "PermissionDecision" }
    ],
    "workspace": [
      { "method": "workspace.open", "params": { "root_path": "string" }, "result": "Workspace" },
      { "method": "workspace.scan", "params": { "workspace_id": "string" }, "result": { "files": "number", "skipped": "number" } },
      { "method": "workspace.tree", "params": { "workspace_id": "string", "max_depth": "number?" }, "result": "TreeNode[]" },
      { "method": "workspace.search", "params": { "workspace_id": "string", "pattern": "string", "glob": "string?" }, "result": "Match[]" },
      { "method": "workspace.file.get", "params": { "workspace_id": "string", "path": "string" }, "result": { "content": "string", "hash": "string" } },
      { "method": "workspace.patch.propose", "params": { "session_id": "string", "diff": "string", "reason": "string" }, "result": "PatchTransaction" },
      { "method": "workspace.patch.apply", "params": { "patch_id": "string" }, "result": "PatchTransaction" },
      { "method": "workspace.patch.rollback", "params": { "patch_id": "string" }, "result": "PatchTransaction" }
    ],
    "capability": [
      { "method": "capability.file.read", "params": { "session_id": "string", "path": "string" }, "result": "PermissionDecision" },
      { "method": "capability.file.write", "params": { "session_id": "string", "path": "string" }, "result": "PermissionDecision" },
      { "method": "capability.command.exec", "params": { "session_id": "string", "command": "string" }, "result": "PermissionDecision" },
      { "method": "capability.network.access", "params": { "session_id": "string", "host": "string" }, "result": "PermissionDecision" },
      { "method": "capability.secret.read", "params": { "session_id": "string", "name": "string" }, "result": "PermissionDecision" },
      { "method": "capability.patch.apply", "params": { "session_id": "string", "patch_id": "string" }, "result": "PermissionDecision" }
    ],
    "worker": [
      { "method": "worker.register", "params": { "name": "string", "kind": "local|remote|ci|sandbox" }, "result": { "worker_id": "string" } },
      { "method": "worker.heartbeat", "params": { "worker_id": "string" }, "result": { "ok": "boolean" } },
      { "method": "worker.assign", "params": { "worker_id": "string", "task_id": "string" }, "result": "Task" },
      { "method": "worker.output.stream", "params": { "worker_id": "string" }, "result": "subscription" },
      { "method": "worker.revoke", "params": { "worker_id": "string" }, "result": { "ok": "boolean" } }
    ],
    "command": [
      { "method": "command.exec", "params": { "session_id": "string", "task_id": "string?", "argv": "string[]" }, "result": { "decision": "PermissionDecision", "result": "CommandResult?" } }
    ],
    "audit": [
      { "method": "audit.report", "params": { "session_id": "string" }, "result": "AuditReport" }
    ],
    "stream": [
      { "method": "session.events.stream", "params": { "session_id": "string" }, "result": "subscription", "notifications": "event" }
    ],
    "daemon": [
      { "method": "daemon.status", "params": {}, "result": { "version": "string", "uptime_seconds": "number", "sessions": "number", "tasks": "number", "workers": "number", "tools": "boolean" } },
      { "method": "daemon.metrics", "params": {}, "result": { "tasks_by_status": "object", "model_usage": "object", "subscribers": "number" } }
    ]
  }
}
