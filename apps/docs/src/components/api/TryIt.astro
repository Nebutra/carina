---
/**
 * JSON-RPC playground (Mintlify-style Try it).
 * - Mock mode: deterministic local responses (no network)
 * - Live mode: POST to user endpoint (daemon / gateway)
 */
interface Props {
  method: string;
  params?: Record<string, string> | object;
  scope?: string;
}

const { method, params = {}, scope = 'read' } = Astro.props;

const sample: Record<string, unknown> = {};
if (params && typeof params === 'object' && !Array.isArray(params)) {
  for (const [key, hint] of Object.entries(params as Record<string, string>)) {
    const h = String(hint).toLowerCase();
    if (key.includes('workspace') || key.includes('path') || key.includes('root')) {
      sample[key] = '/repo';
    } else if (key.includes('session')) {
      sample[key] = 'sess_01J…';
    } else if (key.includes('profile')) {
      sample[key] = 'safe-edit';
    } else if (h.includes('boolean')) {
      sample[key] = true;
    } else if (h.includes('number') || h.includes('integer')) {
      sample[key] = 1;
    } else if (h.includes('array')) {
      sample[key] = [];
    } else if (key.includes('prompt') || key.includes('task')) {
      sample[key] = 'Summarize module boundaries';
    } else if (String(hint).includes('?') && !key.includes('session')) {
      continue;
    } else {
      sample[key] = `<${key}>`;
    }
  }
}

const body = {
  jsonrpc: '2.0',
  id: 1,
  method,
  params: sample,
};
const bodyJson = JSON.stringify(body, null, 2);
---

<div
  class="tryit"
  data-tryit
  data-method={method}
  data-scope={scope}
  data-default-body={bodyJson}
>
  <div class="tryit__head">
    <div class="tryit__title-row">
      <h4 class="tryit__title">Playground</h4>
      <span class="tryit__scope" data-tryit-scope>{scope}</span>
    </div>
    <p class="tryit__hint">
      Mock returns a realistic JSON-RPC envelope without a daemon. Switch to Live to POST to your gateway.
    </p>
  </div>

  <div class="tryit__mode" role="group" aria-label="Playground mode">
    <button type="button" class="tryit__mode-btn is-active" data-tryit-mode="mock" aria-pressed="true">
      Mock
    </button>
    <button type="button" class="tryit__mode-btn" data-tryit-mode="live" aria-pressed="false">
      Live
    </button>
  </div>

  <label class="tryit__field" data-tryit-endpoint-wrap>
    <span>Endpoint</span>
    <input
      type="url"
      class="tryit__input"
      data-tryit-endpoint
      placeholder="http://127.0.0.1:8777/rpc"
      autocomplete="off"
    />
  </label>

  <label class="tryit__field">
    <span>Request body</span>
    <textarea class="tryit__textarea rpc-mono" data-tryit-body rows="8" spellcheck="false">{bodyJson}</textarea>
  </label>

  <div class="tryit__actions">
    <button type="button" class="tryit__btn tryit__btn--ghost" data-tryit-copy-json>Copy JSON</button>
    <button type="button" class="tryit__btn tryit__btn--ghost" data-tryit-copy-curl>Copy curl</button>
    <button type="button" class="tryit__btn tryit__btn--ghost" data-tryit-copy-cli>Copy CLI</button>
    <button type="button" class="tryit__btn tryit__btn--primary" data-tryit-send>Send</button>
  </div>

  <div class="tryit__result" data-tryit-result hidden>
    <div class="tryit__meta" data-tryit-meta></div>
    <pre class="tryit__out rpc-mono" data-tryit-out></pre>
  </div>
</div>

<script>
  import { mockRpcResponse } from '../../scripts/rpc-mock';

  const EP_KEY = 'carina-docs-tryit-endpoint';
  const MODE_KEY = 'carina-docs-tryit-mode';
  const DEFAULT_EP = 'http://127.0.0.1:8777/rpc';

  function init(root: Element) {
    if (!(root instanceof HTMLElement) || root.dataset.ready === '1') return;
    root.dataset.ready = '1';

    const method = root.dataset.method || '';
    const endpointEl = root.querySelector<HTMLInputElement>('[data-tryit-endpoint]');
    const endpointWrap = root.querySelector<HTMLElement>('[data-tryit-endpoint-wrap]');
    const bodyEl = root.querySelector<HTMLTextAreaElement>('[data-tryit-body]');
    const outEl = root.querySelector<HTMLElement>('[data-tryit-out]');
    const resultEl = root.querySelector<HTMLElement>('[data-tryit-result]');
    const metaEl = root.querySelector<HTMLElement>('[data-tryit-meta]');
    const modeBtns = [...root.querySelectorAll<HTMLButtonElement>('[data-tryit-mode]')];
    if (!endpointEl || !bodyEl || !outEl || !resultEl || !metaEl) return;

    let mode = (localStorage.getItem(MODE_KEY) as 'mock' | 'live') || 'mock';
    endpointEl.value = localStorage.getItem(EP_KEY) || DEFAULT_EP;

    const setMode = (next: 'mock' | 'live') => {
      mode = next;
      localStorage.setItem(MODE_KEY, mode);
      modeBtns.forEach((b) => {
        const on = b.dataset.tryitMode === mode;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      if (endpointWrap) endpointWrap.hidden = mode === 'mock';
    };
    setMode(mode);
    modeBtns.forEach((b) =>
      b.addEventListener('click', () => setMode((b.dataset.tryitMode as 'mock' | 'live') || 'mock')),
    );

    const flash = (btn: HTMLButtonElement, ok = true) => {
      const prev = btn.textContent;
      btn.textContent = ok ? 'Copied' : 'Failed';
      btn.classList.add(ok ? 'is-ok' : 'is-err');
      window.setTimeout(() => {
        btn.textContent = prev;
        btn.classList.remove('is-ok', 'is-err');
      }, 1200);
    };

    const getBody = () => bodyEl.value.trim();
    const getEndpoint = () => {
      const v = endpointEl.value.trim() || DEFAULT_EP;
      localStorage.setItem(EP_KEY, v);
      return v;
    };

    const showResult = (opts: {
      ok: boolean;
      statusLabel: string;
      ms: number;
      body: string;
    }) => {
      resultEl.hidden = false;
      resultEl.classList.toggle('is-ok', opts.ok);
      resultEl.classList.toggle('is-err', !opts.ok);
      metaEl.innerHTML = `<span>${opts.statusLabel}</span><span>${opts.ms} ms</span><span>${mode === 'mock' ? 'mock' : 'live'}</span>`;
      outEl.textContent = opts.body;
    };

    root.querySelector<HTMLButtonElement>('[data-tryit-copy-json]')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      try {
        await navigator.clipboard.writeText(getBody());
        flash(btn);
      } catch {
        flash(btn, false);
      }
    });

    root.querySelector<HTMLButtonElement>('[data-tryit-copy-curl]')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const ep = getEndpoint();
      const body = getBody().replace(/'/g, `'\\''`);
      const curl = `curl -sS -X POST '${ep}' \\\n  -H 'Content-Type: application/json' \\\n  -d '${body}'`;
      try {
        await navigator.clipboard.writeText(curl);
        flash(btn);
      } catch {
        flash(btn, false);
      }
    });

    root.querySelector<HTMLButtonElement>('[data-tryit-copy-cli]')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const cli = `carina call ${method}`;
      try {
        await navigator.clipboard.writeText(cli);
        flash(btn);
      } catch {
        flash(btn, false);
      }
    });

    root.querySelector<HTMLButtonElement>('[data-tryit-send]')?.addEventListener('click', async () => {
      let payload: { jsonrpc?: string; id?: unknown; method?: string; params?: Record<string, unknown> };
      try {
        payload = JSON.parse(getBody());
      } catch (err) {
        showResult({
          ok: false,
          statusLabel: 'Invalid JSON',
          ms: 0,
          body: err instanceof Error ? err.message : String(err),
        });
        return;
      }

      if (mode === 'mock') {
        const t0 = performance.now();
        const mocked = mockRpcResponse(payload);
        // artificial delay matches mock latency for UX
        await new Promise((r) => setTimeout(r, mocked.latencyMs));
        const ms = Math.round(performance.now() - t0);
        const hasErr = Boolean((mocked.body as { error?: unknown }).error);
        showResult({
          ok: !hasErr,
          statusLabel: hasErr ? 'JSON-RPC error' : '200 OK',
          ms,
          body: JSON.stringify(mocked.body, null, 2),
        });
        return;
      }

      const ep = getEndpoint();
      const t0 = performance.now();
      try {
        const res = await fetch(ep, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(payload),
        });
        const text = await res.text();
        let pretty = text;
        try {
          pretty = JSON.stringify(JSON.parse(text), null, 2);
        } catch {
          /* raw */
        }
        const ms = Math.round(performance.now() - t0);
        showResult({
          ok: res.ok,
          statusLabel: `HTTP ${res.status} ${res.statusText}`,
          ms,
          body: pretty,
        });
      } catch (err) {
        const ms = Math.round(performance.now() - t0);
        showResult({
          ok: false,
          statusLabel: 'Network error',
          ms,
          body: [
            err instanceof Error ? err.message : String(err),
            '',
            'Daemon/gateway not reachable. Use Mock mode, or start:',
            '  carina-daemon -gateway-ws 127.0.0.1:8777',
          ].join('\n'),
        });
      }
    });
  }

  function boot() {
    document.querySelectorAll('[data-tryit]').forEach(init);
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .tryit {
    margin-top: var(--spacing-3);
    padding: var(--spacing-3);
    border: 1px solid var(--docs-border-subtle);
    border-radius: 10px;
    background: color-mix(in srgb, var(--docs-bg) 55%, var(--docs-bg-surface));
  }

  .tryit__title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .tryit__title {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--docs-fg-subtle);
  }

  .tryit__scope {
    font-family: var(--docs-font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.1rem 0.35rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--docs-accent) 35%, transparent);
    color: var(--docs-accent);
  }

  .tryit__hint {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    color: var(--docs-fg-subtle);
    line-height: 1.45;
  }

  .tryit__mode {
    display: inline-flex;
    gap: 0;
    margin-bottom: 0.75rem;
    border: 1px solid var(--docs-border-subtle);
    border-radius: 8px;
    overflow: hidden;
  }

  .tryit__mode-btn {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--docs-fg-muted);
    font-family: var(--docs-font-sans);
    font-size: 0.72rem;
    font-weight: 550;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
  }

  .tryit__mode-btn.is-active {
    background: color-mix(in srgb, var(--docs-accent) 12%, transparent);
    color: var(--docs-accent);
  }

  .tryit__field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-bottom: var(--spacing-3);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--docs-fg-muted);
  }

  .tryit__input,
  .tryit__textarea {
    width: 100%;
    border: 1px solid var(--docs-border-subtle);
    border-radius: 8px;
    background: var(--docs-bg);
    color: var(--docs-fg);
    font-family: var(--docs-font-mono);
    font-size: 0.75rem;
    line-height: 1.5;
    padding: 0.45rem 0.55rem;
  }

  .tryit__textarea {
    resize: vertical;
    min-height: 8rem;
    tab-size: 2;
  }

  .tryit__input:focus,
  .tryit__textarea:focus {
    outline: none;
    border-color: color-mix(in srgb, var(--docs-accent) 55%, var(--docs-border));
  }

  .tryit__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tryit__btn {
    appearance: none;
    min-height: 1.85rem;
    padding: 0 0.6rem;
    border-radius: 6px;
    font-family: var(--docs-font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid var(--docs-border-subtle);
    background: transparent;
    color: var(--docs-fg-muted);
    transition:
      color 150ms ease,
      border-color 150ms ease,
      background-color 150ms ease;
  }

  .tryit__btn:hover {
    color: var(--docs-fg);
    border-color: var(--docs-border);
  }

  .tryit__btn--primary {
    border-color: color-mix(in srgb, var(--docs-accent) 55%, transparent);
    color: var(--docs-accent);
  }

  .tryit__btn--primary:hover {
    background: color-mix(in srgb, var(--docs-accent) 8%, transparent);
    border-color: var(--docs-accent);
  }

  .tryit__btn.is-ok {
    color: var(--docs-success);
  }

  .tryit__btn.is-err {
    color: var(--docs-danger);
  }

  .tryit__result {
    margin-top: 0.75rem;
    border: 1px solid var(--docs-border-subtle);
    border-radius: 8px;
    overflow: hidden;
  }

  .tryit__result.is-ok {
    border-color: color-mix(in srgb, var(--docs-success) 40%, var(--docs-border-subtle));
  }

  .tryit__result.is-err {
    border-color: color-mix(in srgb, var(--docs-danger) 40%, var(--docs-border-subtle));
  }

  .tryit__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
    padding: 0.4rem 0.65rem;
    font-family: var(--docs-font-mono);
    font-size: 0.6875rem;
    color: var(--docs-fg-muted);
    background: color-mix(in srgb, var(--docs-bg-raised) 70%, transparent);
    border-bottom: 1px solid var(--docs-border-subtle);
  }

  .tryit__result.is-ok .tryit__meta {
    color: var(--docs-success);
  }

  .tryit__result.is-err .tryit__meta {
    color: var(--docs-danger);
  }

  .tryit__out {
    margin: 0;
    padding: 0.55rem 0.65rem;
    max-height: 16rem;
    overflow: auto;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--docs-fg-muted);
    background: var(--docs-bg);
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>
