---
/**
 * Version-pinned protocol method catalog with URL-addressable state.
 */
import stableCatalog from '../../data/rpc-catalog-0.6.x.json';
import nextCatalog from '../../data/rpc-catalog-next.json';
import SnippetTabs from './SnippetTabs.astro';
import TryIt from './TryIt.astro';

interface Props {
  groups?: string[];
  showSnippets?: boolean;
  showTryIt?: boolean;
  version?: '0.6.x' | 'next';
  initial?: boolean;
}

const { groups: only, showSnippets = true, showTryIt = true, version = '0.6.x', initial = true } = Astro.props;
const catalog = version === 'next' ? nextCatalog : stableCatalog;
const isZh = Astro.url.pathname.startsWith('/zh-cn/');
const labels = isZh
  ? {
      filter: '过滤方法', filterPlaceholder: '按方法、参数或结果过滤...', scopes: '按作用域过滤', clear: '清除作用域',
      jump: '跳转到分组', allGroups: '全部分组', showing: '显示', methods: '个方法', params: '参数', field: '字段', type: '类型',
      result: '返回值', sample: '请求示例', empty: '没有符合当前条件的方法。', remote: '远程', control: '控制面', methodLink: '方法链接',
    }
  : {
      filter: 'Filter methods', filterPlaceholder: 'Filter by method, parameter, or result...', scopes: 'Filter by scope', clear: 'Clear scopes',
      jump: 'Jump to group', allGroups: 'All groups', showing: 'Showing', methods: 'methods', params: 'Params', field: 'Field', type: 'Type',
      result: 'Result', sample: 'Sample request', empty: 'No methods match your filter.', remote: 'remote', control: 'control-plane', methodLink: 'Link to method',
    };
const versionKey = version.replace(/[^a-zA-Z0-9]+/g, '-');
const groupList = only
  ? catalog.groups.filter((g) => only.includes(g.id))
  : catalog.groups;

const scopes = ['read', 'write', 'admin', 'worker', 'stream'] as const;
const scopeCounts = Object.fromEntries(
  scopes.map((s) => [
    s,
    groupList.reduce(
      (n, g) => n + g.methods.filter((m) => m.scope === s).length,
      0,
    ),
  ]),
) as Record<(typeof scopes)[number], number>;

const scopeClass: Record<string, string> = {
  read: 'is-read',
  write: 'is-write',
  admin: 'is-admin',
  worker: 'is-worker',
  stream: 'is-stream',
};
const groups = groupList.map((group) => ({
  ...group,
  methods: group.methods.map((method) => {
    const paramEntries =
      typeof method.params === 'object' && method.params && !Array.isArray(method.params)
        ? Object.entries(method.params as Record<string, string>)
        : [];
    const resultText =
      typeof method.result === 'string' ? method.result : JSON.stringify(method.result);
    const paramsObj =
      typeof method.params === 'object' && method.params
        ? (method.params as Record<string, string>)
        : {};
    return {
      ...method,
      anchor: `rpc-${versionKey}-${method.method.replace(/[^a-zA-Z0-9]+/g, '-')}`,
      paramEntries,
      resultText,
      paramsObj,
      hay: `${method.method} ${method.scope} ${resultText} ${paramEntries
        .map(([key]) => key)
        .join(' ')}`.toLowerCase(),
    };
  }),
}));
---

<div
  class="rpc-catalog not-content"
  data-rpc-catalog
  data-version-only={version}
  data-catalog-version={version}
  data-label-showing={labels.showing}
  data-label-methods={labels.methods}
  data-protocol-version={catalog.protocol_version}
  data-method-count={catalog.method_count}
  hidden={!initial}
>
  <div class="rpc-catalog__chrome">
    <div class="rpc-catalog__toolbar">
      <p class="rpc-catalog__meta">
        Protocol <span class="rpc-mono" data-rpc-proto>{catalog.protocol_version}</span>
        · <span class="rpc-mono" data-rpc-count>{catalog.method_count}</span> {labels.methods}
        · <span class="rpc-mono">{catalog.source}</span>
        · channel <span class="rpc-mono">{version}</span>
      </p>
      <label class="rpc-catalog__filter">
        <span class="sr-only">{labels.filter}</span>
        <input
          type="search"
          class="rpc-catalog__search"
          placeholder={labels.filterPlaceholder}
          data-rpc-filter
          autocomplete="off"
        />
      </label>
    </div>

    <div class="rpc-catalog__scopes" role="group" aria-label={labels.scopes}>
      {
        scopes.map((s) => (
          <button
            type="button"
            class:list={['rpc-scope-chip', scopeClass[s]]}
            data-rpc-scope={s}
            aria-pressed="false"
          >
            {s}
            <span class="rpc-scope-chip__n">{scopeCounts[s]}</span>
          </button>
        ))
      }
      <button type="button" class="rpc-scope-chip rpc-scope-chip--clear" data-rpc-scope-clear hidden>
        {labels.clear}
      </button>
    </div>

    <div class="rpc-catalog__jump">
      <label for={`rpc-group-jump-${versionKey}`}>{labels.jump}</label>
      <select id={`rpc-group-jump-${versionKey}`} data-rpc-jump>
        <option value="">{labels.allGroups}</option>
        {
          groups.map((g) => (
            <option value={`rpc-${versionKey}-group-${g.id}`}>
              {g.label} ({g.methods.length})
            </option>
          ))
        }
      </select>
      <span class="rpc-catalog__visible" data-rpc-visible>
        {labels.showing} {catalog.method_count} {labels.methods}
      </span>
    </div>
  </div>

  {
    groups.map((group) => (
      <section class="rpc-group" id={`rpc-${versionKey}-group-${group.id}`} data-rpc-group={group.id}>
        <h2 class="rpc-group__title">
          {group.label}
          <span class="rpc-group__count" data-rpc-group-count data-total={group.methods.length}>{group.methods.length}</span>
        </h2>
        <div class="rpc-group__list">
          {group.methods.map((m) => (
              <details
                class="rpc-method"
                id={m.anchor}
                data-rpc-method
                data-rpc-name={m.method}
                data-rpc-hay={m.hay}
                data-rpc-scope={m.scope}
              >
                <summary>
                  <span class="rpc-method__main">
                    <a class="rpc-method__anchor" href={`#${m.anchor}`} data-rpc-method-anchor aria-label={`${labels.methodLink}: ${m.method}`}>#</a>
                    <span class="rpc-method__name">{m.method}</span>
                    <span class:list={['rpc-method__scope', scopeClass[m.scope] ?? '']}>
                      {m.scope}
                    </span>
                  </span>
                  <span class="rpc-method__flags">
                    {m.remote && <span class="rpc-method__flag">{labels.remote}</span>}
                    {m.control_plane_write && (
                      <span class="rpc-method__flag is-warn">{labels.control}</span>
                    )}
                  </span>
                </summary>
                <div class="rpc-method__body">
                  <div class="rpc-method__cols">
                    <div class="rpc-method__spec">
                      <h4>{labels.params}</h4>
                      {m.paramEntries.length > 0 ? (
                        <div class="rpc-table-wrap">
                          <table>
                            <thead>
                              <tr>
                                <th>{labels.field}</th>
                                <th>{labels.type}</th>
                              </tr>
                            </thead>
                            <tbody>
                              {m.paramEntries.map(([k, v]) => (
                                <tr>
                                  <td class="rpc-mono">{k}</td>
                                  <td class="rpc-mono rpc-type">{String(v)}</td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      ) : (
                        <p class="rpc-method__empty rpc-mono">
                          {typeof m.params === 'string' ? m.params : '{}'}
                        </p>
                      )}
                      <h4>{labels.result}</h4>
                      <pre class="rpc-method__result rpc-mono">{m.resultText}</pre>
                    </div>
                    {showSnippets && (
                      <div class="rpc-method__sample">
                        <h4>{labels.sample}</h4>
                        <SnippetTabs method={m.method} params={m.paramsObj} scope={m.scope} instanceId={`${versionKey}-${m.method}`} />
                        {showTryIt && <TryIt method={m.method} params={m.paramsObj} scope={m.scope} remote={m.remote} />}
                      </div>
                    )}
                  </div>
                </div>
              </details>
          ))}
        </div>
      </section>
    ))
  }

  <p class="rpc-catalog__empty" data-rpc-empty hidden>{labels.empty}</p>
</div>

<script>
  function initCatalog(root: Element) {
    if (!(root instanceof HTMLElement) || root.dataset.ready === '1') return;
    root.dataset.ready = '1';

    const catalogVersion = root.dataset.catalogVersion || '0.6.x';
    const filter = root.querySelector<HTMLInputElement>('[data-rpc-filter]');
    const jump = root.querySelector<HTMLSelectElement>('[data-rpc-jump]');
    const empty = root.querySelector<HTMLElement>('[data-rpc-empty]');
    const visibleEl = root.querySelector<HTMLElement>('[data-rpc-visible]');
    const clearScopes = root.querySelector<HTMLButtonElement>('[data-rpc-scope-clear]');
    const methods = [...root.querySelectorAll<HTMLDetailsElement>('[data-rpc-method]')];
    const groups = [...root.querySelectorAll<HTMLElement>('[data-rpc-group]')];
    const scopeBtns = [...root.querySelectorAll<HTMLButtonElement>('[data-rpc-scope]')];
    const activeScopes = new Set<string>();
    let urlTimer = 0;

    const updateUrlState = () => {
      const url = new URL(window.location.href);
      const query = filter?.value.trim() || '';
      if (query) url.searchParams.set('q', query); else url.searchParams.delete('q');
      if (activeScopes.size) url.searchParams.set('scope', [...activeScopes].sort().join(','));
      else url.searchParams.delete('scope');
      history.replaceState(history.state, '', `${url.pathname}${url.search}${url.hash}`);
    };

    const applyFilter = (syncUrl = true) => {
      const q = (filter?.value || '').trim().toLowerCase();
      let visible = 0;
      methods.forEach((el) => {
        const hay = el.dataset.rpcHay || '';
        const scope = el.dataset.rpcScope || '';
        const scopeOk = activeScopes.size === 0 || activeScopes.has(scope);
        const textOk = !q || hay.includes(q);
        const show = scopeOk && textOk;
        el.hidden = !show;
        if (show) visible += 1;
      });
      groups.forEach((g) => {
        const groupMethods = [...g.querySelectorAll<HTMLElement>('[data-rpc-method]')];
        const count = groupMethods.filter((method) => !method.hidden).length;
        g.hidden = count === 0;
        const countEl = g.querySelector<HTMLElement>('[data-rpc-group-count]');
        if (countEl) countEl.textContent = String(count);
      });
      if (empty) empty.hidden = visible > 0;
      if (visibleEl) visibleEl.textContent = `${root.dataset.labelShowing || 'Showing'} ${visible} ${root.dataset.labelMethods || 'methods'}`;
      if (clearScopes) clearScopes.hidden = activeScopes.size === 0;
      if (syncUrl) {
        window.clearTimeout(urlTimer);
        urlTimer = window.setTimeout(updateUrlState, 120);
      }
    };

    const openMethod = (name: string, scroll = false) => {
      const method = methods.find((item) => item.dataset.rpcName === name);
      if (!method) return;
      method.hidden = false;
      method.open = true;
      method.closest<HTMLElement>('[data-rpc-group]')?.removeAttribute('hidden');
      if (scroll && !root.hidden) {
        const url = new URL(window.location.href);
        url.searchParams.set('method', name);
        url.searchParams.set('version', catalogVersion);
        url.hash = method.id;
        history.replaceState(history.state, '', `${url.pathname}${url.search}${url.hash}`);
        method.scrollIntoView({ behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth', block: 'start' });
      }
    };

    const restoreUrlState = () => {
      const url = new URL(window.location.href);
      if (filter) filter.value = url.searchParams.get('q') || '';
      activeScopes.clear();
      for (const value of (url.searchParams.get('scope') || '').split(',').filter(Boolean)) activeScopes.add(value);
      scopeBtns.forEach((button) => {
        const active = activeScopes.has(button.dataset.rpcScope || '');
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
        button.classList.toggle('is-on', active);
      });
      applyFilter(false);
      const methodName = url.searchParams.get('method');
      if (methodName) openMethod(methodName);
      if (window.location.hash.startsWith(`#rpc-${catalogVersion.replace(/[^a-zA-Z0-9]+/g, '-')}-`)) {
        const target = document.getElementById(window.location.hash.slice(1));
        if (target instanceof HTMLDetailsElement) target.open = true;
      }
    };

    filter?.addEventListener('input', () => applyFilter());
    scopeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const s = btn.dataset.rpcScope || '';
        if (activeScopes.has(s)) {
          activeScopes.delete(s);
          btn.setAttribute('aria-pressed', 'false');
          btn.classList.remove('is-on');
        } else {
          activeScopes.add(s);
          btn.setAttribute('aria-pressed', 'true');
          btn.classList.add('is-on');
        }
        applyFilter(true);
      });
    });
    clearScopes?.addEventListener('click', () => {
      activeScopes.clear();
      scopeBtns.forEach((b) => {
        b.setAttribute('aria-pressed', 'false');
        b.classList.remove('is-on');
      });
      applyFilter(true);
    });
    jump?.addEventListener('change', () => {
      const id = jump.value;
      if (!id) return;
      const target = document.getElementById(id);
      if (target) {
        history.replaceState(history.state, '', `${location.pathname}${location.search}#${id}`);
        target.scrollIntoView({ behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth', block: 'start' });
      }
      jump.value = '';
    });

    methods.forEach((method) => {
      const anchor = method.querySelector<HTMLAnchorElement>('[data-rpc-method-anchor]');
      anchor?.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        const url = new URL(window.location.href);
        const name = method.dataset.rpcName || '';
        url.searchParams.set('method', name);
        url.searchParams.set('version', catalogVersion);
        url.hash = method.id;
        history.replaceState(history.state, '', `${url.pathname}${url.search}${url.hash}`);
        method.open = true;
        method.scrollIntoView({ behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth', block: 'start' });
      });
      method.addEventListener('toggle', () => {
        if (!method.open || root.hidden) return;
        const url = new URL(window.location.href);
        url.searchParams.set('method', method.dataset.rpcName || '');
        url.searchParams.set('version', catalogVersion);
        url.hash = method.id;
        history.replaceState(history.state, '', `${url.pathname}${url.search}${url.hash}`);
      });
    });

    const syncVersion = (event: Event) => {
      if (!root.isConnected) {
        window.removeEventListener('carina:docs-version', syncVersion);
        window.removeEventListener('popstate', syncPopState);
        return;
      }
      const selected = (event as CustomEvent<{ version?: string }>).detail?.version;
      if (selected !== catalogVersion) return;
      const methodName = new URL(window.location.href).searchParams.get('method');
      if (methodName) openMethod(methodName, true);
    };
    const syncPopState = () => {
      if (!root.isConnected) {
        window.removeEventListener('carina:docs-version', syncVersion);
        window.removeEventListener('popstate', syncPopState);
        return;
      }
      restoreUrlState();
    };
    window.addEventListener('carina:docs-version', syncVersion);
    window.addEventListener('popstate', syncPopState);
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('carina:docs-version', syncVersion);
      window.removeEventListener('popstate', syncPopState);
    }, { once: true });

    restoreUrlState();
  }

  function boot() {
    document.querySelectorAll('[data-rpc-catalog]').forEach(initCatalog);
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .rpc-catalog {
    margin: var(--spacing-4) 0 var(--spacing-8);
  }

  .rpc-catalog[hidden] {
    display: none;
  }

  :global(.main-pane:has([data-rpc-catalog]) .sl-container) {
    max-width: 76rem;
  }

  .rpc-mono {
    font-family: var(--docs-font-mono);
    font-size: 0.8125em;
  }

  .rpc-catalog__chrome {
    position: sticky;
    top: var(--docs-nav-height, 5.5rem);
    z-index: 4;
    display: grid;
    grid-template-columns: minmax(12rem, 1fr) auto;
    gap: 0.625rem 0.75rem;
    margin: 0 0 var(--spacing-5);
    padding: var(--spacing-3) 0 var(--spacing-3);
    background: color-mix(in srgb, var(--docs-bg) 92%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--docs-border-subtle);
  }

  .rpc-catalog__toolbar {
    display: contents;
  }

  .rpc-catalog__scopes {
    display: flex;
    flex-wrap: wrap;
    grid-column: 1 / -1;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
  }

  .rpc-scope-chip {
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    min-height: 2.25rem;
    padding: 0 0.65rem;
    border-radius: 999px;
    border: 1px solid var(--docs-border-subtle);
    background: transparent;
    color: var(--docs-fg-muted);
    font-family: var(--docs-font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      color 150ms ease,
      border-color 150ms ease,
      background-color 150ms ease;
  }

  .rpc-scope-chip__n {
    opacity: 0.7;
    font-weight: 500;
  }

  .rpc-scope-chip.is-on,
  .rpc-scope-chip[aria-pressed='true'] {
    color: var(--docs-fg);
    border-color: color-mix(in srgb, var(--docs-accent) 40%, var(--docs-border));
    background: color-mix(in srgb, var(--docs-accent) 10%, transparent);
  }

  .rpc-scope-chip--clear {
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--docs-font-sans);
    font-weight: 500;
  }

  .rpc-scope-chip[hidden] {
    display: none;
  }

  .rpc-catalog__visible {
    margin-inline-start: auto;
    font-size: 0.75rem;
    color: var(--docs-fg-subtle);
    font-family: var(--docs-font-mono);
  }

  .rpc-catalog__meta {
    grid-column: 1 / -1;
    margin: 0;
    font-size: 0.8125rem;
    color: var(--docs-fg-muted);
    line-height: 1.5;
  }

  .rpc-catalog__filter {
    grid-column: 1;
    min-width: 0;
  }

  .rpc-catalog__search {
    width: 100%;
    height: 2.25rem;
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-md);
    background: var(--docs-bg-surface);
    color: var(--docs-fg);
    font-family: var(--docs-font-sans);
    font-size: 0.875rem;
    padding: 0 0.75rem;
    transition: border-color var(--docs-transition), box-shadow var(--docs-transition);
  }

  .rpc-catalog__search:focus {
    outline: none;
    border-color: var(--docs-accent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--docs-accent) 35%, transparent);
  }

  .rpc-catalog__jump {
    display: flex;
    flex-wrap: wrap;
    grid-column: 2;
    grid-row: 2;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0;
    font-size: 0.8125rem;
    color: var(--docs-fg-muted);
  }

  @media (max-width: 52rem) {
    .rpc-catalog__chrome {
      grid-template-columns: minmax(0, 1fr);
    }

    .rpc-catalog__meta,
    .rpc-catalog__filter,
    .rpc-catalog__jump,
    .rpc-catalog__scopes {
      grid-column: 1;
    }

    .rpc-catalog__jump {
      grid-row: auto;
    }

    .rpc-catalog__scopes {
      padding-inline-end: 3.25rem;
    }
  }

  .rpc-catalog__jump select {
    min-height: 2.25rem;
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-md);
    background: var(--docs-bg-surface);
    color: var(--docs-fg);
    font-size: 0.8125rem;
    padding: 0 0.5rem;
    max-width: min(100%, 18rem);
  }

  .rpc-catalog__empty {
    text-align: center;
    color: var(--docs-fg-muted);
    padding: var(--spacing-8);
    border: 1px dashed var(--docs-border-subtle);
    border-radius: var(--docs-radius-lg);
  }

  .rpc-group {
    margin-bottom: var(--spacing-8);
    scroll-margin-top: var(--docs-anchor-offset);
  }

  .rpc-group[hidden] {
    display: none;
  }

  .rpc-group__title {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 var(--spacing-3);
    letter-spacing: 0;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--docs-border-subtle);
  }

  .rpc-group__count {
    font-family: var(--docs-font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--docs-fg-subtle);
  }

  .rpc-method {
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-md);
    background: var(--docs-bg-surface);
    margin-bottom: 0.35rem;
    overflow: hidden;
  }

  .rpc-method[hidden] {
    display: none;
  }

  .rpc-method summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.35rem 0.75rem;
    padding: 0.55rem 0.75rem;
    min-height: 2.5rem;
    transition: background-color var(--docs-transition);
  }

  .rpc-method summary::-webkit-details-marker {
    display: none;
  }

  .rpc-method summary:hover {
    background: color-mix(in srgb, var(--docs-bg-raised) 65%, transparent);
  }

  .rpc-method__main {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 0.55rem;
    min-width: 0;
  }

  .rpc-method__anchor {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    flex: 0 0 auto;
    color: var(--docs-fg-subtle);
    text-decoration: none;
    border-radius: 4px;
  }

  .rpc-method__anchor:hover,
  .rpc-method__anchor:focus-visible {
    color: var(--docs-accent);
    background: color-mix(in srgb, var(--docs-accent) 10%, transparent);
  }

  .rpc-method__name {
    font-family: var(--docs-font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--docs-fg);
    word-break: break-all;
  }

  .rpc-method__scope {
    font-family: var(--docs-font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: uppercase;
    border-radius: 999px;
    padding: 0.12rem 0.4rem;
    line-height: 1.2;
    flex-shrink: 0;
  }

  .rpc-method__scope.is-read {
    color: var(--docs-info);
    background: color-mix(in srgb, var(--docs-info) 12%, transparent);
