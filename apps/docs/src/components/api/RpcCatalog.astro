---
/**
 * Protocol-driven method catalog from src/data/rpc-catalog.json
 * Dense layout + scope chips + per-method try-it builder.
 */
import catalog from '../../data/rpc-catalog.json';
import SnippetTabs from './SnippetTabs.astro';
import TryIt from './TryIt.astro';

interface Props {
  groups?: string[];
  showSnippets?: boolean;
  showTryIt?: boolean;
}

const { groups: only, showSnippets = true, showTryIt = true } = Astro.props;
const groupList = only
  ? catalog.groups.filter((g) => only.includes(g.id))
  : catalog.groups;

const scopes = ['read', 'write', 'admin', 'worker', 'stream'] as const;
const scopeCounts = Object.fromEntries(
  scopes.map((s) => [
    s,
    groupList.reduce(
      (n, g) => n + g.methods.filter((m) => m.scope === s).length,
      0,
    ),
  ]),
) as Record<(typeof scopes)[number], number>;

const scopeClass: Record<string, string> = {
  read: 'is-read',
  write: 'is-write',
  admin: 'is-admin',
  worker: 'is-worker',
  stream: 'is-stream',
};
---

<div
  class="rpc-catalog"
  data-rpc-catalog
  data-protocol-version={catalog.protocol_version}
  data-method-count={catalog.method_count}
>
  <div class="rpc-catalog__chrome">
    <div class="rpc-catalog__toolbar">
      <p class="rpc-catalog__meta">
        Protocol <span class="rpc-mono" data-rpc-proto>{catalog.protocol_version}</span>
        · <span class="rpc-mono" data-rpc-count>{catalog.method_count}</span> methods
        · <span class="rpc-mono">{catalog.source}</span>
        · channel <span class="rpc-mono" data-rpc-channel>0.6.x</span>
      </p>
      <label class="rpc-catalog__filter">
        <span class="sr-only">Filter methods</span>
        <input
          type="search"
          class="rpc-catalog__search"
          placeholder="Filter methods…"
          data-rpc-filter
          autocomplete="off"
        />
      </label>
    </div>

    <div class="rpc-catalog__scopes" role="group" aria-label="Filter by scope">
      {
        scopes.map((s) => (
          <button
            type="button"
            class:list={['rpc-scope-chip', scopeClass[s]]}
            data-rpc-scope={s}
            aria-pressed="false"
          >
            {s}
            <span class="rpc-scope-chip__n">{scopeCounts[s]}</span>
          </button>
        ))
      }
      <button type="button" class="rpc-scope-chip rpc-scope-chip--clear" data-rpc-scope-clear hidden>
        Clear scopes
      </button>
    </div>

    <div class="rpc-catalog__jump">
      <label for="rpc-group-jump">Jump to group</label>
      <select id="rpc-group-jump" data-rpc-jump>
        <option value="">All groups</option>
        {
          groupList.map((g) => (
            <option value={`group-${g.id}`}>
              {g.label} ({g.methods.length})
            </option>
          ))
        }
      </select>
      <span class="rpc-catalog__visible" data-rpc-visible>
        Showing {catalog.method_count}
      </span>
    </div>
  </div>

  {
    groupList.map((group) => (
      <section class="rpc-group" id={`group-${group.id}`} data-rpc-group={group.id}>
        <h2 class="rpc-group__title">
          {group.label}
          <span class="rpc-group__count">{group.methods.length}</span>
        </h2>
        <div class="rpc-group__list">
          {group.methods.map((m) => {
            const paramEntries =
              typeof m.params === 'object' && m.params && !Array.isArray(m.params)
                ? Object.entries(m.params as Record<string, string>)
                : [];
            const resultText =
              typeof m.result === 'string' ? m.result : JSON.stringify(m.result);
            const hay = `${m.method} ${m.scope} ${resultText} ${paramEntries.map(([k]) => k).join(' ')}`.toLowerCase();
            const paramsObj =
              typeof m.params === 'object' && m.params
                ? (m.params as Record<string, string>)
                : {};
            return (
              <details
                class="rpc-method"
                data-rpc-method
                data-rpc-hay={hay}
                data-rpc-scope={m.scope}
              >
                <summary>
                  <span class="rpc-method__main">
                    <span class="rpc-method__name">{m.method}</span>
                    <span class:list={['rpc-method__scope', scopeClass[m.scope] ?? '']}>
                      {m.scope}
                    </span>
                  </span>
                  <span class="rpc-method__flags">
                    {m.remote && <span class="rpc-method__flag">remote</span>}
                    {m.control_plane_write && (
                      <span class="rpc-method__flag is-warn">control-plane</span>
                    )}
                  </span>
                </summary>
                <div class="rpc-method__body">
                  <div class="rpc-method__cols">
                    <div class="rpc-method__spec">
                      <h4>Params</h4>
                      {paramEntries.length > 0 ? (
                        <div class="rpc-table-wrap">
                          <table>
                            <thead>
                              <tr>
                                <th>Field</th>
                                <th>Type</th>
                              </tr>
                            </thead>
                            <tbody>
                              {paramEntries.map(([k, v]) => (
                                <tr>
                                  <td class="rpc-mono">{k}</td>
                                  <td class="rpc-mono rpc-type">{String(v)}</td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      ) : (
                        <p class="rpc-method__empty rpc-mono">
                          {typeof m.params === 'string' ? m.params : '{}'}
                        </p>
                      )}
                      <h4>Result</h4>
                      <pre class="rpc-method__result rpc-mono">{resultText}</pre>
                    </div>
                    {showSnippets && (
                      <div class="rpc-method__sample">
                        <h4>Sample request</h4>
                        <SnippetTabs method={m.method} params={paramsObj} scope={m.scope} />
                        {showTryIt && <TryIt method={m.method} params={paramsObj} scope={m.scope} />}
                      </div>
                    )}
                  </div>
                </div>
              </details>
            );
          })}
        </div>
      </section>
    ))
  }

  <p class="rpc-catalog__empty" data-rpc-empty hidden>No methods match your filter.</p>
</div>

<script>
  function initCatalog(root: Element) {
    if (!(root instanceof HTMLElement) || root.dataset.ready === '1') return;
    root.dataset.ready = '1';

    const filter = root.querySelector<HTMLInputElement>('[data-rpc-filter]');
    const jump = root.querySelector<HTMLSelectElement>('[data-rpc-jump]');
    const empty = root.querySelector<HTMLElement>('[data-rpc-empty]');
    const visibleEl = root.querySelector<HTMLElement>('[data-rpc-visible]');
    const clearScopes = root.querySelector<HTMLButtonElement>('[data-rpc-scope-clear]');
    const channelEl = root.querySelector<HTMLElement>('[data-rpc-channel]');
    const methods = [...root.querySelectorAll<HTMLElement>('[data-rpc-method]')];
    const groups = [...root.querySelectorAll<HTMLElement>('[data-rpc-group]')];
    const scopeBtns = [...root.querySelectorAll<HTMLButtonElement>('[data-rpc-scope]')];
    const activeScopes = new Set<string>();

    const applyFilter = () => {
      const q = (filter?.value || '').trim().toLowerCase();
      let visible = 0;
      methods.forEach((el) => {
        const hay = el.dataset.rpcHay || '';
        const scope = el.dataset.rpcScope || '';
        const scopeOk = activeScopes.size === 0 || activeScopes.has(scope);
        const textOk = !q || hay.includes(q);
        const show = scopeOk && textOk;
        el.hidden = !show;
        if (show) visible += 1;
      });
      groups.forEach((g) => {
        const any = [...g.querySelectorAll<HTMLElement>('[data-rpc-method]')].some((m) => !m.hidden);
        g.hidden = !any;
      });
      if (empty) empty.hidden = visible > 0;
      if (visibleEl) visibleEl.textContent = `Showing ${visible}`;
      if (clearScopes) clearScopes.hidden = activeScopes.size === 0;
    };

    filter?.addEventListener('input', applyFilter);
    scopeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const s = btn.dataset.rpcScope || '';
        if (activeScopes.has(s)) {
          activeScopes.delete(s);
          btn.setAttribute('aria-pressed', 'false');
          btn.classList.remove('is-on');
        } else {
          activeScopes.add(s);
          btn.setAttribute('aria-pressed', 'true');
          btn.classList.add('is-on');
        }
        applyFilter();
      });
    });
    clearScopes?.addEventListener('click', () => {
      activeScopes.clear();
      scopeBtns.forEach((b) => {
        b.setAttribute('aria-pressed', 'false');
        b.classList.remove('is-on');
      });
      applyFilter();
    });
    jump?.addEventListener('change', () => {
      const id = jump.value;
      if (!id) return;
      document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      jump.value = '';
    });

    const syncChannelLabel = () => {
      const ch = document.documentElement.dataset.docsVersion || '0.6.x';
      if (channelEl) channelEl.textContent = ch;
    };
    syncChannelLabel();
    window.addEventListener('carina:docs-version', syncChannelLabel as EventListener);

    applyFilter();
  }

  function boot() {
    document.querySelectorAll('[data-rpc-catalog]').forEach(initCatalog);
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .rpc-catalog {
    margin: var(--spacing-4) 0 var(--spacing-8);
  }

  .rpc-mono {
    font-family: var(--docs-font-mono);
    font-size: 0.8125em;
  }

  .rpc-catalog__chrome {
    position: sticky;
    top: var(--docs-nav-height, 5.5rem);
    z-index: 4;
    margin: 0 0 var(--spacing-5);
    padding: var(--spacing-3) 0 var(--spacing-3);
    background: color-mix(in srgb, var(--docs-bg) 92%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--docs-border-subtle);
  }

  .rpc-catalog__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-3);
    margin-bottom: var(--spacing-3);
  }

  .rpc-catalog__scopes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: var(--spacing-3);
  }

  .rpc-scope-chip {
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    min-height: 1.6rem;
    padding: 0 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--docs-border-subtle);
    background: transparent;
    color: var(--docs-fg-muted);
    font-family: var(--docs-font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      color 150ms ease,
      border-color 150ms ease,
      background-color 150ms ease;
  }

  .rpc-scope-chip__n {
    opacity: 0.7;
    font-weight: 500;
  }

  .rpc-scope-chip.is-on,
  .rpc-scope-chip[aria-pressed='true'] {
    color: var(--docs-fg);
    border-color: color-mix(in srgb, var(--docs-accent) 40%, var(--docs-border));
    background: color-mix(in srgb, var(--docs-accent) 10%, transparent);
  }

  .rpc-scope-chip--clear {
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--docs-font-sans);
    font-weight: 500;
  }

  .rpc-catalog__visible {
    margin-inline-start: auto;
    font-size: 0.75rem;
    color: var(--docs-fg-subtle);
    font-family: var(--docs-font-mono);
  }

  .rpc-catalog__meta {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--docs-fg-muted);
    line-height: 1.5;
  }

  .rpc-catalog__filter {
    flex: 1 1 14rem;
    max-width: 22rem;
  }

  .rpc-catalog__search {
    width: 100%;
    height: 2.25rem;
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-md);
    background: var(--docs-bg-surface);
    color: var(--docs-fg);
    font-family: var(--docs-font-sans);
    font-size: 0.875rem;
    padding: 0 0.75rem;
    transition: border-color var(--docs-transition), box-shadow var(--docs-transition);
  }

  .rpc-catalog__search:focus {
    outline: none;
    border-color: var(--docs-accent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--docs-accent) 35%, transparent);
  }

  .rpc-catalog__jump {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0;
    font-size: 0.8125rem;
    color: var(--docs-fg-muted);
  }

  .rpc-catalog__jump select {
    height: 2rem;
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-md);
    background: var(--docs-bg-surface);
    color: var(--docs-fg);
    font-size: 0.8125rem;
    padding: 0 0.5rem;
    max-width: min(100%, 18rem);
  }

  .rpc-catalog__empty {
    text-align: center;
    color: var(--docs-fg-muted);
    padding: var(--spacing-8);
    border: 1px dashed var(--docs-border-subtle);
    border-radius: var(--docs-radius-lg);
  }

  .rpc-group {
    margin-bottom: var(--spacing-8);
    scroll-margin-top: var(--docs-anchor-offset);
  }

  .rpc-group[hidden] {
    display: none;
  }

  .rpc-group__title {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 var(--spacing-3);
    letter-spacing: -0.015em;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--docs-border-subtle);
  }

  .rpc-group__count {
    font-family: var(--docs-font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--docs-fg-subtle);
  }

  .rpc-method {
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-md);
    background: var(--docs-bg-surface);
    margin-bottom: 0.35rem;
    overflow: hidden;
  }

  .rpc-method[hidden] {
    display: none;
  }

  .rpc-method summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.35rem 0.75rem;
    padding: 0.55rem 0.75rem;
    min-height: 2.5rem;
    transition: background-color var(--docs-transition);
  }

  .rpc-method summary::-webkit-details-marker {
    display: none;
  }

  .rpc-method summary:hover {
    background: color-mix(in srgb, var(--docs-bg-raised) 65%, transparent);
  }

  .rpc-method__main {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 0.55rem;
    min-width: 0;
  }

  .rpc-method__name {
    font-family: var(--docs-font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--docs-fg);
    word-break: break-all;
  }

  .rpc-method__scope {
    font-family: var(--docs-font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
    padding: 0.12rem 0.4rem;
    line-height: 1.2;
    flex-shrink: 0;
  }

  .rpc-method__scope.is-read {
    color: var(--docs-info);
    background: color-mix(in srgb, var(--docs-info) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--docs-info) 28%, transparent);
  }
  .rpc-method__scope.is-write {
    color: var(--docs-accent);
    background: color-mix(in srgb, var(--docs-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--docs-accent) 28%, transparent);
  }
  .rpc-method__scope.is-admin {
    color: var(--docs-warning);
    background: color-mix(in srgb, var(--docs-warning) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--docs-warning) 28%, transparent);
  }
  .rpc-method__scope.is-worker,
  .rpc-method__scope.is-stream {
    color: var(--docs-fg-muted);
    background: var(--docs-bg-raised);
    border: 1px solid var(--docs-border-subtle);
  }

  .rpc-method__flags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    flex-shrink: 0;
  }

  .rpc-method__flag {
    font-size: 0.625rem;
    font-family: var(--docs-font-mono);
    color: var(--docs-fg-subtle);
    border: 1px solid var(--docs-border-subtle);
    border-radius: 999px;
    padding: 0.1rem 0.35rem;
    line-height: 1.2;
  }

  .rpc-method__flag.is-warn {
    color: var(--docs-warning);
    border-color: color-mix(in srgb, var(--docs-warning) 35%, transparent);
  }

  .rpc-method__body {
    padding: 0 0.75rem 0.85rem;
    border-top: 1px solid var(--docs-border-subtle);
  }

  .rpc-method__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
    padding-top: var(--spacing-3);
  }

  @media (min-width: 960px) {
    .rpc-method__cols {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
      align-items: start;
    }
  }

  .rpc-method__body h4 {
    margin: 0 0 0.4rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--docs-fg-subtle);
  }

  .rpc-table-wrap {
    overflow-x: auto;
    margin-bottom: var(--spacing-3);
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-md);
  }

  .rpc-table-wrap table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    margin: 0;
  }

  .rpc-table-wrap th,
  .rpc-table-wrap td {
    border-bottom: 1px solid var(--docs-border-subtle);
    border-inline-end: 1px solid var(--docs-border-subtle);
    padding: 0.4rem 0.55rem;
    text-align: left;
    vertical-align: top;
  }

  .rpc-table-wrap th:last-child,
  .rpc-table-wrap td:last-child {
    border-inline-end: 0;
  }

  .rpc-table-wrap tr:last-child td {
    border-bottom: 0;
  }

  .rpc-table-wrap th {
    background: var(--docs-bg-raised);
    font-weight: 500;
    color: var(--docs-fg-muted);
    white-space: nowrap;
  }

  /* Plain mono — no chips; keep identifiers on one line */
  .rpc-table-wrap td.rpc-mono,
  .rpc-type {
    font-family: var(--docs-font-mono);
    font-size: 0.78rem;
    color: var(--docs-fg);
    background: transparent;
    border-radius: 0;
    padding: 0.4rem 0.55rem;
    white-space: nowrap;
    word-break: normal;
    overflow-wrap: normal;
  }

  .rpc-method__empty {
    margin: 0 0 var(--spacing-3);
    color: var(--docs-fg-muted);
    font-size: 0.8125rem;
  }

  .rpc-method__result {
    margin: 0;
    padding: 0.55rem 0.65rem;
    background: var(--docs-bg);
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-md);
    font-family: var(--docs-font-mono);
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--docs-fg-muted);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .rpc-method__sample {
    min-width: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
