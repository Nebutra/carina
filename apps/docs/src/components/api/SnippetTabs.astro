---
/**
 * Multi-language request snippets for a JSON-RPC method.
 * Uses Astro <Code /> (Shiki) + Carina mineral theme for real highlighting.
 */
import { Code } from 'astro:components';
import { carinaDark } from '../../themes/carina-code.mjs';

interface Props {
  method: string;
  params?: Record<string, unknown> | string | object;
  scope?: string;
}

const { method, params = {}, scope = 'read' } = Astro.props;

const paramsObj =
  params && typeof params === 'object' && !Array.isArray(params)
    ? (params as Record<string, string>)
    : {};

function sampleParams(src: Record<string, string>): Record<string, unknown> {
  const out: Record<string, unknown> = {};
  for (const [key, hint] of Object.entries(src)) {
    const h = String(hint).toLowerCase();
    if (key === 'workspace_root' || key.includes('path') || key.includes('root')) {
      out[key] = '/repo';
    } else if (key.includes('session')) {
      out[key] = 'sess_01J…';
    } else if (key.includes('profile')) {
      out[key] = 'safe-edit';
    } else if (h.includes('boolean')) {
      out[key] = true;
    } else if (h.includes('number') || h.includes('integer')) {
      out[key] = 1;
    } else if (h.includes('array') || h.includes('[]')) {
      out[key] = [];
    } else if (key.includes('prompt') || key.includes('task')) {
      out[key] = 'Summarize module boundaries';
    } else {
      if (String(hint).includes('?') && !key.includes('session')) continue;
      out[key] = `<${key}>`;
    }
  }
  return out;
}

const sample = sampleParams(paramsObj);
const jsonRpc = {
  jsonrpc: '2.0',
  id: 1,
  method,
  params: sample,
};
const jsonText = JSON.stringify(jsonRpc, null, 2);
const paramsTs = JSON.stringify(sample, null, 2);
const tsText = `// scope: ${scope}
const result = await client.request(${JSON.stringify(method)}, ${paramsTs});`;
const bashText = `# JSON-RPC over the local socket
carina call ${method}

# equivalent payload:
# ${JSON.stringify(jsonRpc)}`;

const panels = [
  { id: 'json', label: 'JSON-RPC', lang: 'json' as const, code: jsonText },
  { id: 'ts', label: 'TypeScript', lang: 'ts' as const, code: tsText },
  { id: 'bash', label: 'CLI', lang: 'bash' as const, code: bashText },
];
---

<div class="snippet-tabs" data-snippet-tabs>
  <div class="snippet-tabs__list" role="tablist" aria-label="Code samples">
    {
      panels.map((p, i) => (
        <button
          type="button"
          class:list={['snippet-tabs__tab', i === 0 && 'is-active']}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-panel={p.id}
        >
          {p.label}
        </button>
      ))
    }
    <button type="button" class="snippet-tabs__copy" data-snippet-copy aria-label="Copy snippet">
      Copy
    </button>
  </div>
  <div class="snippet-tabs__panels">
    {
      panels.map((p, i) => (
        <div
          class:list={['snippet-tabs__panel', i === 0 && 'is-active']}
          data-panel={p.id}
          data-code={p.code}
          role="tabpanel"
          hidden={i !== 0}
        >
          <Code code={p.code} lang={p.lang} theme={carinaDark} />
        </div>
      ))
    }
  </div>
</div>

<script>
  function init(root: Element) {
    if (!(root instanceof HTMLElement) || root.dataset.ready === '1') return;
    root.dataset.ready = '1';
    const tabs = root.querySelectorAll<HTMLButtonElement>('.snippet-tabs__tab');
    const panels = root.querySelectorAll<HTMLElement>('.snippet-tabs__panel');
    const copyBtn = root.querySelector<HTMLButtonElement>('[data-snippet-copy]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.panel;
        tabs.forEach((t) => {
          const on = t === tab;
          t.classList.toggle('is-active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        panels.forEach((p) => {
          const on = p.dataset.panel === id;
          p.hidden = !on;
          p.classList.toggle('is-active', on);
        });
      });
    });

    copyBtn?.addEventListener('click', async () => {
      const active = root.querySelector<HTMLElement>('.snippet-tabs__panel.is-active');
      const text = active?.dataset.code ?? active?.innerText ?? '';
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        const prev = copyBtn.textContent;
        copyBtn.textContent = 'Copied';
        copyBtn.classList.add('is-copied');
        window.setTimeout(() => {
          copyBtn.textContent = prev;
          copyBtn.classList.remove('is-copied');
        }, 1400);
      } catch {
        /* ignore */
      }
    });
  }
  function boot() {
    document.querySelectorAll('[data-snippet-tabs]').forEach(init);
  }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .snippet-tabs {
    margin: 0;
    border: 1px solid var(--polish-code-border, var(--carina-border-subtle));
    border-radius: 8px;
    overflow: hidden;
    background: var(--polish-code-bg, var(--carina-surface));
    max-width: 100%;
    box-shadow: inset 0 1px 0 color-mix(in srgb, #f3f0e8 5%, transparent);
  }

  .snippet-tabs__list {
    display: flex;
    align-items: stretch;
    gap: 0;
    height: 2.375rem;
    border-bottom: 1px solid var(--polish-code-border, var(--carina-border-subtle));
    background: var(--polish-code-chrome, var(--carina-surface-raised));
    padding: 0 0.35rem 0 0.45rem;
    box-sizing: border-box;
  }

  .snippet-tabs__tab {
    position: relative;
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--polish-code-muted, var(--carina-dust));
    font-family: var(--docs-font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1;
    height: 100%;
    padding: 0 0.75rem;
    margin: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 160ms ease;
  }

  .snippet-tabs__tab::after {
    content: '';
    position: absolute;
    left: 0.5rem;
    right: 0.5rem;
    bottom: 0;
    height: 1.5px;
    border-radius: 1px 1px 0 0;
    background: transparent;
  }

  .snippet-tabs__tab.is-active {
    color: var(--polish-code-fg, var(--carina-starlight));
    font-weight: 600;
  }

  .snippet-tabs__tab.is-active::after {
    background: var(--carina-ion-cyan, var(--docs-accent));
  }

  .snippet-tabs__tab:focus-visible {
    outline: 2px solid var(--docs-focus);
    outline-offset: -2px;
  }

  .snippet-tabs__copy {
    appearance: none;
    margin-inline-start: auto;
    align-self: center;
    height: 1.65rem;
    padding: 0 0.55rem;
    border: 1px solid var(--polish-code-border, var(--carina-border-subtle));
    border-radius: 6px;
    background: transparent;
    color: var(--polish-code-muted, var(--carina-dust));
    font-family: var(--docs-font-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .snippet-tabs__copy:hover {
    color: var(--polish-code-fg, var(--carina-starlight));
    border-color: var(--carina-border, #344144);
    background: color-mix(in srgb, var(--polish-code-bg, #12181a) 70%, transparent);
  }

  .snippet-tabs__copy.is-copied {
    color: var(--carina-spectral-green, #68d2a3);
    border-color: color-mix(in srgb, var(--carina-spectral-green, #68d2a3) 40%, transparent);
  }

  .snippet-tabs__panels {
    min-width: 0;
  }

  .snippet-tabs__panel {
    margin: 0;
    padding: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
    scrollbar-width: thin;
    scrollbar-color: #344144 transparent;
  }

  .snippet-tabs__panel[hidden] {
    display: none;
  }

  /* Astro <Code /> shell — strip default padding/borders into our mineral card */
  .snippet-tabs__panel :global(pre) {
    margin: 0 !important;
    padding: 0.9rem 1.05rem !important;
    border: 0 !important;
    border-radius: 0 !important;
    background: transparent !important;
    overflow-x: auto;
    font-size: 0.78rem !important;
    line-height: 1.6 !important;
    tab-size: 2;
  }

  .snippet-tabs__panel :global(pre code) {
    display: block;
    font-family: var(--docs-font-mono) !important;
    font-size: inherit !important;
    font-weight: 400 !important;
    line-height: inherit !important;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    box-shadow: none !important;
    white-space: pre;
  }
</style>
