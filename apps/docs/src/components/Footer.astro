---
/**
 * Footer: feedback + product links + default Starlight meta/pagination.
 */
import Default from '@astrojs/starlight/components/Footer.astro';
import PageFeedback from './PageFeedback.astro';

const { entry, locale } = Astro.locals.starlightRoute;
const isSplash = entry.data.template === 'splash';
const isZh = locale === 'zh-cn';
const localePrefix = isZh ? '/zh-cn' : '';
const docsHref = (path: string) => `${localePrefix}${path}`;
const labels = isZh
  ? {
      agents: '面向 Agent 的文档',
      currentMarkdown: '当前页面的 Markdown',
      methodCatalog: '方法目录',
      versionChannels: '版本通道',
      catalogJson: '目录 JSON',
      product: '产品',
      quickstart: '快速上手',
      faq: '常见问题',
    }
  : {
      agents: 'Docs for agents',
      currentMarkdown: 'This page as Markdown',
      methodCatalog: 'Method catalog',
      versionChannels: 'Version channels',
      catalogJson: 'Catalog JSON',
      product: 'Product',
      quickstart: 'Quickstart',
      faq: 'FAQ',
    };
---

<PageFeedback />

{
  !isSplash && (
    <div class="docs-footer-links">
      <div class="docs-footer-links__grid">
        <div>
          <p class="docs-footer-links__h">{labels.agents}</p>
          <ul>
            <li><a href="/llms.txt">llms.txt</a></li>
            <li><a href="/llms-full.txt">llms-full.txt</a></li>
            <li><a href="/skill.md">skill.md</a></li>
            <li><a href="index.md">{labels.currentMarkdown}</a></li>
          </ul>
        </div>
        <div>
          <p class="docs-footer-links__h">API</p>
          <ul>
            <li><a href={docsHref('/api/methods/')}>{labels.methodCatalog}</a></li>
            <li><a href={docsHref('/api/versions/')}>{labels.versionChannels}</a></li>
            <li><a href="/data/rpc-catalog-next.json">{labels.catalogJson}</a></li>
          </ul>
        </div>
        <div>
          <p class="docs-footer-links__h">{labels.product}</p>
          <ul>
            <li><a href={docsHref('/getting-started/quickstart/')}>{labels.quickstart}</a></li>
            <li><a href="https://github.com/nebutra/carina" rel="noopener">GitHub</a></li>
            <li><a href={docsHref('/deployment/faq/')}>{labels.faq}</a></li>
          </ul>
        </div>
      </div>
    </div>
  )
}

<Default><slot /></Default>

<style>
  .docs-footer-links {
    margin-top: var(--spacing-8);
    padding-top: var(--spacing-6);
    border-top: 1px solid var(--docs-border-subtle);
  }

  .docs-footer-links__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: var(--spacing-5);
    margin-bottom: var(--spacing-6);
  }

  .docs-footer-links__h {
    margin: 0 0 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--docs-fg-subtle);
  }

  .docs-footer-links ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .docs-footer-links li {
    margin: 0.25rem 0;
  }

  .docs-footer-links a {
    font-size: 0.8125rem;
    color: var(--docs-fg-muted);
    text-decoration: none;
  }

  .docs-footer-links a:hover {
    color: var(--docs-accent);
  }
</style>
