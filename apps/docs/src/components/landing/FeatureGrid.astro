---
/**
 * Feature grid — docs landing navigation cards.
 *
 * Best-practice sources applied:
 *  - UX Collective “8 best practices for UI card design”:
 *      fixed card height, truncate overflow, 8pt spacing, clear states
 *  - Mintlify landing FeatureCard:
 *      whole-card link, border-only hover, title + short desc, no lift
 *  - CSS Grid equal-height cards:
 *      stretch + flex column + CTA margin-top: auto
 *  - Card hierarchy: visual → title → body → single CTA
 *
 * Brand: outline / surface only — no drop shadows (docs/brand AGENTS.md).
 */
import type { Category } from '../ui/CategoryTag.astro';

interface Feature {
  title: string;
  description: string;
  category: Category;
  categoryLabel: string;
  href?: string;
}

interface Props {
  heading?: string;
  subheading?: string;
  features: Feature[];
  moreLabel?: string;
}

const {
  heading = 'Built for governed agent execution',
  subheading = 'Policy per action. Hash-chained audit. Transactional rollback. Local authority.',
  features,
  moreLabel = 'Learn more',
} = Astro.props;

const capColor: Record<Category, string> = {
  core: 'var(--docs-cap-core)',
  agent: 'var(--docs-cap-agent)',
  tool: 'var(--docs-cap-tool)',
  memory: 'var(--docs-cap-memory)',
  observability: 'var(--docs-cap-observability)',
  success: 'var(--docs-success)',
  warning: 'var(--docs-warning)',
  danger: 'var(--docs-danger)',
};

/** Minimal monoline icons — fixed 20×20 viewBox, same stroke weight. */
const icons: Record<string, string> = {
  core: 'M12 3l7 4v6c0 4-3 7-7 8-4-1-7-4-7-8V7l7-4z',
  agent: 'M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm-7 9a7 7 0 0 1 14 0',
  tool: 'M14.7 6.3a4 4 0 0 0-5.4 5.4L4 17l3 3 5.3-5.3a4 4 0 0 0 5.4-5.4L15 12l-2.3-2.3 1.9-3.4z',
  memory: 'M4 7h16v10H4zM8 7V5h8v2M9 12h6',
  observability: 'M3 12h4l2-6 4 12 2-6h6',
  success: 'M5 13l4 4L19 7',
  warning: 'M12 9v4m0 4h.01M10.3 4.3L2.6 18a2 2 0 0 0 1.7 3h15.4a2 2 0 0 0 1.7-3L13.7 4.3a2 2 0 0 0-3.4 0z',
  danger: 'M12 9v4m0 4h.01M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18z',
};
---

<section class="features">
  <div class="features__header">
    <h2 class="features__heading">{heading}</h2>
    <p class="features__sub">{subheading}</p>
  </div>
  <ul class="features__grid" role="list">
    {
      features.map((f, i) => {
        const color = capColor[f.category] ?? capColor.core;
        const path = icons[f.category] ?? icons.core;
        const inner = (
          <>
            <div class="feature-card__top">
              <span class="feature-card__icon" style={`--icon-color: ${color}`} aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path
                    d={path}
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <span class="feature-card__label">{f.categoryLabel}</span>
            </div>
            <h3 class="feature-card__title">{f.title}</h3>
            <p class="feature-card__desc">{f.description}</p>
            {f.href && (
              <span class="feature-card__more">
                {moreLabel}
                <span class="feature-card__arrow" aria-hidden="true">→</span>
              </span>
            )}
          </>
        );

        return (
          <li
            class:list={[
              'feature-card',
              'docs-animate-in',
              `docs-animate-in--${Math.min(i + 1, 4)}`,
            ]}
            style={`animation-delay: calc(var(--docs-hero-stagger) * ${i + 1}); --card-accent: ${color}`}
          >
            {f.href ? (
              <a class="feature-card__link" href={f.href}>
                {inner}
              </a>
            ) : (
              <div class="feature-card__link feature-card__link--static">{inner}</div>
            )}
          </li>
        );
      })
    }
  </ul>
</section>

<style>
  .features {
    max-width: var(--docs-page-max);
    margin: 0 auto;
    padding: var(--spacing-16) var(--spacing-6);
  }

  @media (min-width: 768px) {
    .features {
      padding: var(--spacing-20) var(--spacing-10);
    }
  }

  .features__header {
    max-width: 38rem;
    margin: 0 auto 2.5rem; /* 40px — 8pt system */
    text-align: center;
  }

  .features__heading {
    margin: 0 0 0.75rem;
    font-size: clamp(1.5rem, 2.8vw, 1.875rem); /* 24–30px */
    font-weight: var(--font-weight-semibold);
    color: var(--docs-fg);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .features__sub {
    margin: 0;
    color: var(--docs-fg-muted);
    font-size: 1rem; /* body ≥16px for scannable section lead */
    line-height: 1.65;
  }

  /*
   * Equal-height grid:
   *  - stretch items fill row
   *  - grid-auto-rows: 1fr equalizes row tracks when content differs
   *  - fixed internal slots (title/desc) keep visual rhythm
   */
  .features__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem; /* 16px minimum between cards */
    align-items: stretch;
    grid-auto-rows: 1fr;
  }

  @media (min-width: 640px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .features__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem; /* 20px desktop */
    }
  }

  .feature-card {
    display: flex;
    min-height: 0;
    height: 100%;
    margin: 0;
    padding: 0;
    border-radius: 12px; /* rounded-xl, Mintlify-adjacent */
    background: transparent;
  }

  .feature-card__link {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    width: 100%;
    min-height: 14.5rem; /* fixed skeleton (UX Collective #5) */
    padding: 1.5rem; /* 24px — 8pt */
    box-sizing: border-box;
    text-decoration: none;
    color: inherit;
    background: color-mix(in srgb, var(--docs-bg-surface) 88%, transparent);
    border: 1px solid var(--docs-border-subtle);
    border-radius: 12px;
    transition:
      border-color 160ms cubic-bezier(0.2, 0, 0, 1),
      background-color 160ms cubic-bezier(0.2, 0, 0, 1);
  }

  .feature-card__link--static {
    cursor: default;
  }

  /* Default → Hover → Active → Focus (UX Collective #8) */
  .feature-card__link:hover {
    border-color: color-mix(in srgb, var(--card-accent, var(--docs-accent)) 45%, var(--docs-border));
    background: var(--docs-bg-surface);
  }

  .feature-card__link:active {
    background: color-mix(in srgb, var(--docs-fg) 3.5%, var(--docs-bg-surface));
    border-color: color-mix(in srgb, var(--card-accent, var(--docs-accent)) 55%, var(--docs-border));
  }

  .feature-card__link:focus-visible {
    outline: none;
    border-color: var(--docs-accent);
    box-shadow:
      0 0 0 2px var(--docs-bg),
      0 0 0 4px color-mix(in srgb, var(--docs-accent) 55%, transparent);
  }

  /* Visual anchor: fixed 36×36 tile — equal width, no ragged tag edges */
  .feature-card__top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 2.25rem;
    margin-bottom: 1rem; /* 16px */
  }

  .feature-card__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 8px;
    color: var(--icon-color);
    background: color-mix(in srgb, var(--icon-color) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--icon-color) 28%, transparent);
  }

  .feature-card__label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--docs-fg-muted);
    line-height: 1;
  }

  .feature-card__title {
    margin: 0 0 0.5rem;
    min-height: calc(1.3em * 2); /* 2-line title slot */
    font-size: 1.125rem; /* 18px — hierarchy above body */
    font-weight: var(--font-weight-semibold);
    color: var(--docs-fg);
    line-height: 1.3;
    letter-spacing: -0.015em;
    transition: color 160ms cubic-bezier(0.2, 0, 0, 1);
  }

  .feature-card__link:hover .feature-card__title {
    color: var(--docs-accent);
  }

  .feature-card__desc {
    margin: 0;
    flex: 1 1 auto; /* push CTA to baseline */
    min-height: calc(1.55em * 3);
    max-height: calc(1.55em * 3);
    color: var(--docs-fg-muted);
    font-size: 0.9375rem; /* 15px — readable, not micro */
    line-height: 1.55;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
  }

  .feature-card__more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: auto; /* pin CTA to card bottom */
    padding-top: 1rem;
    font-size: 0.875rem; /* ≥ body-sm, not smaller than body */
    font-weight: 500;
    color: var(--docs-fg-muted);
    transition: color 160ms cubic-bezier(0.2, 0, 0, 1);
  }

  .feature-card__arrow {
    display: inline-block;
    transition: transform 160ms cubic-bezier(0.2, 0, 0, 1);
  }

  .feature-card__link:hover .feature-card__more,
  .feature-card__link:focus-visible .feature-card__more {
    color: var(--docs-accent);
  }

  .feature-card__link:hover .feature-card__arrow,
  .feature-card__link:focus-visible .feature-card__arrow {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card__link,
    .feature-card__title,
    .feature-card__more,
    .feature-card__arrow {
      transition: none;
    }
  }
</style>
