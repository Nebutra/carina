---
/**
 * Landing Hero.
 * Brand mark: wordmark/logo SVG for small chrome (not Display Alpha at caption size).
 * Title / subtitle: Geist Sans (product heading + body roles).
 * Display Alpha only used optionally for a large pure-Latin identity lockup.
 */
interface Props {
  brand?: string;
  title: string;
  subtitle: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  /** Show large Display-Alpha "Carina" above the title (pure Latin only). */
  showIdentityLockup?: boolean;
}

const {
  brand = 'Carina',
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  showIdentityLockup = false,
} = Astro.props;
---

<section class="hero">
  <div class="hero__inner">
    <p class="hero__eyebrow docs-animate-in docs-animate-in--1">
      <img
        class="hero__mark"
        src="/carina-symbol.svg"
        alt=""
        width="16"
        height="16"
        decoding="async"
      />
      <span class="hero__brand-label">{brand}</span>
      <span class="hero__divider" aria-hidden="true">·</span>
      <span class="hero__product">AI Agent Runtime</span>
    </p>

    {
      showIdentityLockup && (
        <p class="hero__identity font-brand font-brand--display docs-animate-in docs-animate-in--1" aria-hidden="true">
          Carina
        </p>
      )
    }

    <h1 class="hero__title docs-animate-in docs-animate-in--2">{title}</h1>
    <p class="hero__subtitle docs-animate-in docs-animate-in--3">{subtitle}</p>
    <div class="hero__actions docs-animate-in docs-animate-in--4">
      <a class="hero__btn hero__btn--primary" href={primaryCta.href}>{primaryCta.label}</a>
      {
        secondaryCta && (
          <a class="hero__btn hero__btn--ghost" href={secondaryCta.href}>
            {secondaryCta.label}
            <span aria-hidden="true">→</span>
          </a>
        )
      }
    </div>
  </div>
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__grid" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: var(--spacing-20) var(--spacing-6) var(--spacing-16);
    border-bottom: 1px solid var(--docs-border-subtle);
  }

  @media (min-width: 768px) {
    .hero {
      padding: clamp(5rem, 10vw, 7.5rem) var(--spacing-10) var(--spacing-20);
    }
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 var(--spacing-6);
    padding: 0.28rem 0.75rem 0.28rem 0.45rem;
    border: 1px solid var(--docs-border);
    border-radius: var(--docs-radius-full);
    background: color-mix(in srgb, var(--docs-bg-surface) 90%, transparent);
    color: var(--docs-fg-muted);
    font-family: var(--docs-font-sans);
    font-size: var(--text-caption);
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  .hero__mark {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    display: block;
  }

  .hero__brand-label {
    color: var(--docs-fg);
    font-weight: 600;
    font-family: var(--docs-font-sans);
  }

  .hero__divider {
    color: var(--docs-fg-subtle);
    font-weight: 400;
  }

  .hero__product {
    font-weight: 400;
  }

  /* Optional large identity — Display Alpha, pure Latin only */
  .hero__identity {
    margin: 0 0 var(--spacing-4);
    color: var(--docs-fg);
    opacity: 0.92;
  }

  .hero__title {
    margin: 0 0 var(--spacing-5);
    font-family: var(--docs-font-display);
    font-size: clamp(2.15rem, 5.4vw, 3.4rem);
    font-weight: 550;
    line-height: 1.06;
    letter-spacing: -0.022em;
    color: var(--docs-fg);
    text-wrap: balance;
    font-optical-sizing: auto;
    /* CJK: break at spaces/punctuation, never inside a word like 执行 */
    word-break: keep-all;
    line-break: strict;
  }

  .hero__subtitle {
    margin: 0 auto var(--spacing-8);
    max-width: 36rem;
    font-family: var(--docs-font-sans);
    font-size: clamp(0.98rem, 1.4vw, 1.08rem);
    font-weight: 400;
    line-height: 1.7;
    color: var(--docs-fg-muted);
    text-wrap: pretty;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    justify-content: center;
    align-items: center;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    min-height: var(--docs-control-h);
    padding: 0 var(--spacing-6);
    border-radius: var(--docs-radius-full);
    font-family: var(--docs-font-sans);
    font-size: var(--text-body-sm);
    font-weight: 500;
    text-decoration: none;
    transition:
      background-color var(--docs-transition),
      border-color var(--docs-transition),
      color var(--docs-transition),
      box-shadow var(--docs-transition),
      transform var(--docs-transition);
  }

  .hero__btn:focus-visible {
    outline: 2px solid var(--docs-focus);
    outline-offset: 2px;
  }

  /* Outline CTAs only — design system: no solid fills */
  .hero__btn--primary {
    background: transparent;
    color: var(--docs-accent);
    border: 1px solid color-mix(in srgb, var(--docs-accent) 65%, transparent);
    -webkit-text-fill-color: var(--docs-accent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--docs-accent) 25%, transparent);
  }

  .hero__btn--primary:hover {
    background: color-mix(in srgb, var(--docs-accent) 8%, transparent);
    border-color: var(--docs-accent);
    color: var(--docs-accent-hover);
    -webkit-text-fill-color: var(--docs-accent-hover);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--docs-accent) 45%, transparent);
    transform: translateY(-1px);
  }

  .hero__btn--ghost {
    background: transparent;
    color: var(--docs-fg);
    -webkit-text-fill-color: var(--docs-fg);
    border: 1px solid var(--docs-border);
  }

  .hero__btn--ghost:hover {
    border-color: color-mix(in srgb, var(--docs-fg) 35%, var(--docs-border));
    background: color-mix(in srgb, var(--docs-fg) 3%, transparent);
    color: var(--docs-fg);
    -webkit-text-fill-color: var(--docs-fg);
    transform: translateY(-1px);
  }

  .hero__glow {
    pointer-events: none;
    position: absolute;
    inset: -25% 5% auto;
    height: 70%;
    background: radial-gradient(
      ellipse at 50% 0%,
      color-mix(in srgb, var(--docs-accent) 16%, transparent),
      transparent 68%
    );
    z-index: 0;
    animation: docs-glow-pulse 6s var(--docs-ease) infinite alternate;
  }

  .hero__grid {
    pointer-events: none;
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.35;
    background-image:
      linear-gradient(color-mix(in srgb, var(--docs-border-subtle) 55%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--docs-border-subtle) 55%, transparent) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at 50% 30%, black 10%, transparent 70%);
  }

  @keyframes docs-glow-pulse {
    from {
      opacity: 0.75;
      transform: scale(1);
    }
    to {
      opacity: 1;
      transform: scale(1.04);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__glow {
      animation: none;
    }
  }
</style>
