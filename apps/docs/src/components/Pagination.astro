---
/**
 * Mintlify-style prev/next: label + title + optional page description.
 */
import Default from '@astrojs/starlight/components/Pagination.astro';

// Prefer default Starlight markup; we restyle via CSS and inject descriptions client-side
// from sidebar link title attributes when available.
---

<div class="docs-pagination" data-docs-pagination>
  <Default><slot /></Default>
</div>

<script>
  function enhance() {
    document.querySelectorAll<HTMLElement>('[data-docs-pagination]').forEach((root) => {
      if (root.dataset.ready === '1') return;
      root.dataset.ready = '1';
      root.querySelectorAll<HTMLAnchorElement>('.pagination-links a').forEach((a) => {
        // Pull description from matching sidebar link if present
        const href = a.getAttribute('href');
        if (!href) return;
        const side = document.querySelector<HTMLAnchorElement>(
          `nav.sidebar a[href="${href}"], .sidebar-content a[href="${href}"]`,
        );
        const desc =
          side?.getAttribute('title') ||
          side?.getAttribute('aria-description') ||
          side?.dataset.description;
        if (!desc) return;
        if (a.querySelector('.docs-pagination__desc')) return;
        const el = document.createElement('span');
        el.className = 'docs-pagination__desc';
        el.textContent = desc;
        const host = a.querySelector('span') || a;
        host.appendChild(el);
      });
    });
  }
  enhance();
  document.addEventListener('astro:page-load', enhance);
</script>

<style is:global>
  .docs-pagination .pagination-links {
    border-top: 1px solid var(--docs-border-subtle);
    padding-top: 1.5rem;
    margin-top: 0.5rem;
  }

  .docs-pagination .pagination-links a {
    border: 1px solid var(--docs-border-subtle) !important;
    border-radius: 10px !important;
    background: color-mix(in srgb, var(--docs-bg-surface) 70%, transparent) !important;
    box-shadow: none !important;
    padding: 1rem 1.1rem !important;
    transition:
      border-color 160ms ease,
      background-color 160ms ease !important;
  }

  .docs-pagination .pagination-links a:hover {
    border-color: color-mix(in srgb, var(--docs-accent) 35%, var(--docs-border)) !important;
    background: var(--docs-bg-surface) !important;
  }

  .docs-pagination .pagination-links .link-title {
    font-size: 1.05rem !important;
    font-weight: 600 !important;
    color: var(--docs-fg) !important;
    line-height: 1.3 !important;
  }

  .docs-pagination .docs-pagination__desc {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--docs-fg-muted);
    line-height: 1.45;
  }
</style>
