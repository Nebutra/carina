---
/**
 * Path breadcrumb under page title (Mintlify-style).
 * Built from the current docs entry id + locale prefix.
 */
import { sectionEntries } from '../config/section-entries.mjs';

const { entry, locale } = Astro.locals.starlightRoute;
const zh = locale === 'zh-cn';
const id = entry.id; // e.g. "concepts/runtime" or "zh-cn/concepts/runtime"
const isSplash = entry.data.template === 'splash';

const parts = id.split('/').filter(Boolean);
// Drop locale prefix segment when present
const localeKeys = ['zh-cn'];
const pathParts =
  parts[0] && localeKeys.includes(parts[0]) ? parts.slice(1) : parts;

const homeHref = locale === 'root' || !locale ? '/' : `/${locale}/`;
const crumbs: { label: string; href?: string }[] = [
  { label: zh ? '文档' : 'Docs', href: homeHref },
];
const zhSections: Record<string, string> = {
  agents: '智能体',
  api: 'API',
  concepts: '核心概念',
  deployment: '部署与运维',
  'getting-started': '入门',
  memory: '记忆',
  observability: '可观测性',
  reference: '参考',
  tools: '工具',
  use: '使用 Carina',
  workflows: '工作流',
};

for (let i = 0; i < pathParts.length; i++) {
  const seg = pathParts[i]!;
  const isLast = i === pathParts.length - 1;
  const label =
    (zh ? zhSections[seg] : undefined) ??
    seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
  const localePrefix = locale === 'root' || !locale ? '' : `/${locale}`;
  const sectionTarget =
    i === 0 && seg in sectionEntries
      ? sectionEntries[seg as keyof typeof sectionEntries]
      : undefined;
  crumbs.push({
    label: isLast ? entry.data.title : label,
    href: isLast
      ? undefined
      : sectionTarget
        ? `${localePrefix}/${sectionTarget}/`
        : undefined,
  });
}
---

{
  !isSplash && pathParts.length > 0 && (
    <nav class="docs-breadcrumb" aria-label={zh ? '面包屑导航' : 'Breadcrumb'}>
      <ol>
        {crumbs.map((c, i) => (
          <li>
            {i > 0 && (
              <span class="docs-breadcrumb__sep" aria-hidden="true">
                /
              </span>
            )}
            {c.href ? <a href={c.href}>{c.label}</a> : <span aria-current="page">{c.label}</span>}
          </li>
        ))}
      </ol>
    </nav>
  )
}

<style>
  .docs-breadcrumb {
    margin: 0 0 var(--spacing-3);
  }

  .docs-breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.15rem 0;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.8125rem;
    color: var(--docs-fg-subtle);
  }

  .docs-breadcrumb li {
    display: inline-flex;
    align-items: center;
    min-width: 0;
  }

  .docs-breadcrumb a {
    color: var(--docs-fg-muted);
    text-decoration: none;
    transition: color var(--docs-transition);
  }

  .docs-breadcrumb a:hover {
    color: var(--docs-accent);
  }

  .docs-breadcrumb span[aria-current='page'] {
    color: var(--docs-fg-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 28ch;
  }

  .docs-breadcrumb__sep {
    margin-inline: 0.4rem;
    color: var(--docs-fg-subtle);
    user-select: none;
  }
</style>
