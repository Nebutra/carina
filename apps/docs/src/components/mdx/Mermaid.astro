---
/**
 * Client-rendered Mermaid diagram.
 *
 * Prefer the `code` prop (JS template string) so MDX/smartypants cannot rewrite
 * `-->` arrows into em-dashes. Slot content is supported with dash repair.
 */
interface Props {
  caption?: string;
  /** Diagram source. Prefer over the default slot. */
  code?: string;
}

const { caption, code: codeProp } = Astro.props;
const zh = Astro.locals.starlightRoute.locale === 'zh-cn';
const raw = codeProp ?? (await Astro.slots.render('default'));

/**
 * Strip MDX wrappers / entities and repair typographers that break Mermaid.
 * Smartypants turns `-->` into `—>` (em dash + >), which Mermaid rejects.
 */
function normalizeMermaidSource(input: string): string {
  return (
    input
      .replace(/<[^>]+>/g, '')
      .replace(/&lt;/g, '<')
      .replace(/&gt;/g, '>')
      .replace(/&amp;/g, '&')
      .replace(/&quot;/g, '"')
      .replace(/&#39;/g, "'")
      .replace(/\u00a0/g, ' ')
      // Any unicode dash(es) immediately before `>` → Mermaid edge arrow
      .replace(/[\u2010\u2011\u2012\u2013\u2014\u2212\uFE58\uFE63\uFF0D]-*>/g, '-->')
      // Bare single-hyphen edges that lost a dash: `A -> B` (not `A --> B`)
      .replace(/([^\-\s])\s*->(?!>)/g, '$1 -->')
      .trim()
  );
}

const code = normalizeMermaidSource(String(raw));
---

<figure class="docs-mermaid" data-mermaid>
  <pre class="docs-mermaid__src" data-mermaid-src hidden>{code}</pre>
  <div
    class="docs-mermaid__canvas"
    data-mermaid-canvas
    data-error-label={zh ? '图表渲染失败。' : 'Diagram failed to render.'}
    aria-label={zh ? '图表' : 'Diagram'}
  ></div>
  {caption && <figcaption class="docs-mermaid__cap">{caption}</figcaption>}
</figure>

<script>
  let mermaidReady: Promise<typeof import('mermaid')> | null = null;

  async function getMermaid() {
    if (!mermaidReady) {
      mermaidReady = import('mermaid').then(async (m) => {
        const mermaid = m.default;
        const dark =
          document.documentElement.dataset.theme === 'dark' ||
          document.documentElement.dataset.theme === 'carina-dark' ||
          (!document.documentElement.dataset.theme &&
            window.matchMedia('(prefers-color-scheme: dark)').matches);
        mermaid.initialize({
          startOnLoad: false,
          securityLevel: 'strict',
          theme: dark ? 'dark' : 'neutral',
          fontFamily: 'var(--docs-font-sans, ui-sans-serif, system-ui, sans-serif)',
        });
        return m;
      });
    }
    return mermaidReady;
  }

  /** Mermaid may inject error SVGs on document body when parse/render fails. */
  function scrubStrayMermaidErrors(id: string) {
    for (const sel of [`#${CSS.escape(id)}`, `#d${CSS.escape(id)}`]) {
      document.querySelectorAll(sel).forEach((el) => {
        if (!el.closest('[data-mermaid]')) el.remove();
      });
    }
    // Error bomb SVGs Mermaid sometimes leaves on <body>
    document.querySelectorAll('body > svg').forEach((el) => {
      const text = el.textContent ?? '';
      if (text.includes('Syntax error') || text.includes('mermaid version')) {
        el.remove();
      }
    });
  }

  async function renderOne(root: HTMLElement) {
    if (root.dataset.rendered === '1') return;
    const src = root.querySelector<HTMLElement>('[data-mermaid-src]')?.textContent?.trim();
    const canvas = root.querySelector<HTMLElement>('[data-mermaid-canvas]');
    if (!src || !canvas) return;

    const id = `mmd-${Math.random().toString(36).slice(2, 10)}`;
    try {
      const mod = await getMermaid();
      await mod.default.parse(src);
      const { svg } = await mod.default.render(id, src);
      canvas.innerHTML = svg;
      root.dataset.rendered = '1';
    } catch (err) {
      scrubStrayMermaidErrors(id);
      const error = document.createElement('p');
      error.className = 'docs-mermaid__err';
      error.textContent = canvas.dataset.errorLabel || 'Diagram failed to render.';
      canvas.replaceChildren(error);
      console.warn('[docs-mermaid]', err, src);
      root.dataset.rendered = '1';
    }
  }

  function boot() {
    document.querySelectorAll<HTMLElement>('[data-mermaid]').forEach((el) => {
      el.dataset.rendered = '';
      void renderOne(el);
    });
  }

  boot();
  document.addEventListener('astro:page-load', boot);
  const mo = new MutationObserver(() => {
    document.querySelectorAll<HTMLElement>('[data-mermaid]').forEach((el) => {
      el.dataset.rendered = '';
    });
    boot();
  });
  mo.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>

<style>
  .docs-mermaid {
    margin: 1.5rem 0;
  }

  .docs-mermaid__canvas {
    border: 1px solid var(--docs-border-subtle);
    border-radius: 12px;
    background: color-mix(in srgb, var(--docs-bg-surface) 85%, transparent);
    padding: 1rem;
    overflow-x: auto;
  }

  .docs-mermaid__canvas :global(svg) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
  }

  .docs-mermaid__cap {
    margin-top: 0.5rem;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--docs-fg-subtle);
  }

  .docs-mermaid__err {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--docs-danger);
  }
</style>
