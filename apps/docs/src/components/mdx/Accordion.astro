---
/**
 * Accordion group. Children: <AccordionItem title="...">...</AccordionItem>
 *
 * Hash deep-links: opening an item writes its slug to the URL hash via
 * history.replaceState (no back-button pollution); on load, a matching hash
 * opens the item and scrolls it into view.
 */
---

<div class="docs-accordion">
  <slot />
</div>

<script>
  function reducedMotion(): boolean {
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  }

  function initAccordion(root: Element) {
    if (!(root instanceof HTMLElement) || root.dataset.ready === '1') return;
    root.dataset.ready = '1';

    root.querySelectorAll<HTMLDetailsElement>('details[id]').forEach((item) => {
      item.addEventListener('toggle', () => {
        if (item.open) {
          history.replaceState(null, '', `#${item.id}`);
        } else if (decodeURIComponent(location.hash.slice(1)) === item.id) {
          history.replaceState(null, '', location.pathname + location.search);
        }
      });
    });
  }

  function openFromHash() {
    const hash = decodeURIComponent(location.hash.slice(1));
    if (!hash) return;
    const target = document.getElementById(hash);
    if (
      target instanceof HTMLDetailsElement &&
      target.closest('.docs-accordion') &&
      !target.open
    ) {
      target.open = true;
      requestAnimationFrame(() => {
        target.scrollIntoView({
          behavior: reducedMotion() ? 'auto' : 'smooth',
          block: 'start',
        });
      });
    }
  }

  function boot() {
    document.querySelectorAll('.docs-accordion').forEach(initAccordion);
    openFromHash();
  }

  boot();
  document.addEventListener('astro:page-load', boot);
  // Same-document hash navigation (in-page links to an item) opens it too.
  window.addEventListener('hashchange', openFromHash);
</script>

<style>
  .docs-accordion {
    margin: var(--spacing-6) 0;
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-lg);
    overflow: hidden;
    background: var(--docs-bg-surface);
  }

  .docs-accordion :global(details) {
    border-bottom: 1px solid var(--docs-border-subtle);
    /* Neutralize Starlight's generic markdown <details> chrome (2px start
       rule + 1rem inline padding) — the accordion card owns its frame. */
    border-inline-start: 0;
    padding-inline-start: 0;
    /* Hash deep-link scroll lands below the sticky navbar */
    scroll-margin-top: var(--docs-anchor-offset);
  }

  .docs-accordion :global(details:last-child) {
    border-bottom: 0;
  }

  .docs-accordion :global(summary) {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-3);
    /* Undo Starlight's marker-compensation offset so titles start-align */
    margin-inline-start: 0;
    padding: 0.85rem 1rem;
    font-size: 0.9375rem;
    font-weight: 550;
    color: var(--docs-fg);
    transition: background-color var(--docs-transition);
  }

  .docs-accordion :global(summary::-webkit-details-marker) {
    display: none;
  }

  /* Starlight markdown.css draws its own chevron on summary::before —
     suppress it; this accordion renders a single ::after chevron. */
  .docs-accordion :global(summary::before) {
    content: none;
    display: none;
  }

  /* Starlight adds margin-bottom: 1rem to open summaries; the body panel
     owns its own padding, so drop it. */
  .docs-accordion :global(details[open] > summary) {
    margin-bottom: 0;
  }

  .docs-accordion :global(summary:hover) {
    background: color-mix(in srgb, var(--docs-bg-raised) 70%, transparent);
  }

  .docs-accordion :global(summary:focus-visible) {
    outline: 2px solid var(--docs-focus);
    outline-offset: -2px;
  }

  .docs-accordion :global(summary::after) {
    content: '';
    width: 0.45rem;
    height: 0.45rem;
    border-inline-end: 1.5px solid var(--docs-fg-muted);
    border-bottom: 1.5px solid var(--docs-fg-muted);
    transform: rotate(45deg);
    transition: transform var(--docs-transition);
    flex-shrink: 0;
  }

  .docs-accordion :global(details[open] summary::after) {
    transform: rotate(225deg);
    margin-top: 0.2rem;
  }

  .docs-accordion :global(.docs-accordion__body) {
    padding: 0 1rem 1rem;
    color: var(--docs-fg-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  .docs-accordion :global(.docs-accordion__body > :first-child) {
    margin-top: 0;
  }

  .docs-accordion :global(.docs-accordion__body > :last-child) {
    margin-bottom: 0;
  }
</style>
