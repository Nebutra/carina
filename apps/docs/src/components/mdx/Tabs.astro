---
/**
 * Client-side tab group (Code Group / content tabs).
 * Children: <Tab label="...">...</Tab>
 * WAI-ARIA: arrow keys, Home/End, roving tabindex.
 * Panel switch: GSAP autoAlpha crossfade (docs-motion).
 *
 * Sync + persistence (Mintlify/Anthropic behavior): groups sharing a
 * `syncKey` (default: joined tab labels, so identical language groups sync
 * automatically) switch together and persist to localStorage
 * (`carina-tabs:<key>`), restored during init before first paint.
 */
import { uniqueId } from './id';

interface Props {
  /** Groups with the same key sync selection + persist it. */
  syncKey?: string;
}

const { syncKey } = Astro.props;
const groupId = uniqueId('tabs');
---

<div class="docs-tabs" data-tabs={groupId} data-sync-key={syncKey}>
  <div class="docs-tabs__list" role="tablist"></div>
  <div class="docs-tabs__panels">
    <slot />
  </div>
</div>

<script>
  import { crossfadePanel } from '../../scripts/docs-motion';

  const STORE_PREFIX = 'carina-tabs:';
  const SYNC_EVENT = 'carina:tabs-sync';

  type SyncDetail = { key: string; label: string; source: HTMLElement };

  function readSaved(key: string): string | null {
    try {
      return localStorage.getItem(STORE_PREFIX + key);
    } catch {
      return null;
    }
  }

  function persist(key: string, label: string): void {
    try {
      localStorage.setItem(STORE_PREFIX + key, label);
    } catch {
      /* private mode / quota — sync still works in-page */
    }
  }

  function initTabs(root: Element) {
    if (!(root instanceof HTMLElement) || root.dataset.ready === '1') return;
    root.dataset.ready = '1';

    const list = root.querySelector('.docs-tabs__list');
    const panels = [...root.querySelectorAll<HTMLElement>('.docs-tab')];
    if (!list || panels.length === 0) return;

    const labels = panels.map((p, i) => p.dataset.label || `Tab ${i + 1}`);
    const syncKey = root.dataset.syncKey || labels.join('|');

    // Restore persisted selection before building chrome → no flicker.
    let initial = 0;
    const saved = readSaved(syncKey);
    if (saved !== null) {
      const idx = labels.indexOf(saved);
      if (idx >= 0) initial = idx;
    }

    list.innerHTML = '';
    const buttons: HTMLButtonElement[] = [];
    let active = initial;
    let busy = false;

    const setChrome = (i: number, focus = false) => {
      buttons.forEach((b, j) => {
        const on = j === i;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-selected', on ? 'true' : 'false');
        b.tabIndex = on ? 0 : -1;
      });
      panels.forEach((p, j) => {
        p.setAttribute('tabindex', j === i ? '0' : '-1');
      });
      if (focus) buttons[i]?.focus();
    };

    /** Instant switch (persisted restore + cross-group sync — no tween). */
    const applyInstant = (i: number) => {
      if (i === active || i < 0 || i >= panels.length) return;
      setChrome(i);
      active = i;
      panels.forEach((p, j) => {
        const on = j === i;
        p.hidden = !on;
        p.classList.toggle('is-active', on);
        p.style.removeProperty('opacity');
        p.style.removeProperty('visibility');
        p.style.removeProperty('transform');
      });
    };

    const select = (i: number, focus = false) => {
      if (i === active || busy || i < 0 || i >= panels.length) {
        if (focus) buttons[i]?.focus();
        return;
      }
      const from = panels[active];
      const to = panels[i];
      busy = true;
      setChrome(i, focus);
      active = i;

      crossfadePanel({
        from,
        to,
        onSwitch: () => {
          /* chrome already updated; ensure inactive stay hidden after tween */
        },
      });

      // Persist + broadcast to same-key groups on the page.
      persist(syncKey, labels[i]);
      document.dispatchEvent(
        new CustomEvent<SyncDetail>(SYNC_EVENT, {
          detail: { key: syncKey, label: labels[i], source: root },
        }),
      );

      // Allow next click after in-tween settles (out 0.12 + in 0.2)
      window.setTimeout(() => {
        busy = false;
        panels.forEach((p, j) => {
          if (j !== active) {
            p.hidden = true;
            p.classList.remove('is-active');
          }
        });
      }, 360);
    };

    const onSync = (e: Event) => {
      if (!root.isConnected) {
        document.removeEventListener(SYNC_EVENT, onSync);
        return;
      }
      const detail = (e as CustomEvent<SyncDetail>).detail;
      if (!detail || detail.key !== syncKey || detail.source === root) return;
      const idx = labels.indexOf(detail.label);
      if (idx >= 0) applyInstant(idx);
    };
    document.addEventListener(SYNC_EVENT, onSync);

    panels.forEach((panel, i) => {
      const id = panel.id || `${root.dataset.tabs}-panel-${i}`;
      panel.id = id;
      panel.setAttribute('role', 'tabpanel');
      panel.setAttribute('aria-labelledby', `${id}-tab`);
      panel.hidden = i !== initial;
      panel.classList.toggle('is-active', i === initial);
      panel.setAttribute('tabindex', i === initial ? '0' : '-1');

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'docs-tabs__tab';
      btn.setAttribute('role', 'tab');
      btn.setAttribute('aria-selected', i === initial ? 'true' : 'false');
      btn.setAttribute('aria-controls', id);
      btn.id = `${id}-tab`;
      btn.tabIndex = i === initial ? 0 : -1;
      btn.textContent = labels[i];
      if (i === initial) btn.classList.add('is-active');

      btn.addEventListener('click', () => select(i));
      btn.addEventListener('keydown', (e) => {
        const n = buttons.length;
        let next = i;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = (i + 1) % n;
        else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') next = (i - 1 + n) % n;
        else if (e.key === 'Home') next = 0;
        else if (e.key === 'End') next = n - 1;
        else return;
        e.preventDefault();
        select(next, true);
      });

      buttons.push(btn);
      list.appendChild(btn);
    });
  }

  function boot() {
    document.querySelectorAll('[data-tabs]').forEach(initTabs);
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .docs-tabs {
    margin: var(--spacing-6) 0;
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-lg);
    background: var(--docs-bg-surface);
    overflow: hidden;
  }

  .docs-tabs__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    border-bottom: 1px solid var(--docs-border-subtle);
    background: color-mix(in srgb, var(--docs-bg) 50%, var(--docs-bg-surface));
    padding: 0 0.35rem;
  }

  .docs-tabs__list :global(.docs-tabs__tab) {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--docs-fg-muted);
    font-family: var(--docs-font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.7rem 0.85rem;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    /*
     * Starlight's markdown sibling rule (`* + *`-style) injects
     * margin-top: 1rem on every button after the first; the first tab then
     * flex-stretches 1rem taller than its siblings. Neutralize here.
     */
    margin-block-start: 0;
    margin-bottom: -1px;
    transition:
      color var(--docs-transition),
      border-color var(--docs-transition);
  }

  .docs-tabs__list :global(.docs-tabs__tab:hover) {
    color: var(--docs-fg);
  }

  .docs-tabs__list :global(.docs-tabs__tab.is-active) {
    color: var(--docs-fg);
    border-bottom-color: var(--docs-accent);
  }

  .docs-tabs__list :global(.docs-tabs__tab:focus-visible) {
    outline: 2px solid var(--docs-focus);
    outline-offset: -2px;
  }

  .docs-tabs__panels {
    /* Same Starlight sibling rule adds margin-top: 1rem here — it reads as a
       stray light band between the tab strip and a code-group's dark card. */
    margin-block-start: 0;
    padding: var(--spacing-4) var(--spacing-5);
    /* Stable paint box while GSAP swaps panels */
    position: relative;
  }

  /* When a tab only holds a code fence, drop inner padding (Code Group look) */
  .docs-tabs__panels:has(.expressive-code) {
    padding: 0;
  }

  .docs-tabs__panels :global(.docs-tab[hidden]) {
    display: none;
  }

  .docs-tabs__panels :global(.docs-tab > :first-child) {
    margin-top: 0;
  }

  .docs-tabs__panels :global(.docs-tab > :last-child) {
    margin-bottom: 0;
  }
</style>
