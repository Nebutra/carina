---
/**
 * Full header: brand + search + version + theme/lang, section tabs, version banner.
 */
import config from 'virtual:starlight/user-config';
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import Search from '@astrojs/starlight/components/Search.astro';
import SiteTitle from '@astrojs/starlight/components/SiteTitle.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';
import ThemeSelect from '@astrojs/starlight/components/ThemeSelect.astro';
import VersionSelector from './ui/VersionSelector.astro';
import VersionBanner from './VersionBanner.astro';

type SidebarEntry =
  | { type: 'link'; href: string; label: string; isCurrent: boolean }
  | { type: 'group'; label: string; entries: SidebarEntry[] };

const { sidebar } = Astro.locals.starlightRoute;
const hasSidebar = Astro.locals.starlightRoute.hasSidebar;

const shouldRenderSearch =
  config.pagefind ||
  config.components.Search !== '@astrojs/starlight/components/Search.astro';

function firstLink(entries: SidebarEntry[]): string | undefined {
  for (const e of entries) {
    if (e.type === 'link') return e.href;
    const nested = firstLink(e.entries);
    if (nested) return nested;
  }
  return undefined;
}

function containsCurrent(entries: SidebarEntry[]): boolean {
  return entries.some((e) =>
    e.type === 'link' ? e.isCurrent : containsCurrent(e.entries),
  );
}

const tabs = hasSidebar
  ? (sidebar as SidebarEntry[])
      .filter((e): e is Extract<SidebarEntry, { type: 'group' }> => e.type === 'group')
      .map((group) => ({
        label: group.label,
        href: firstLink(group.entries),
        active: containsCurrent(group.entries),
      }))
      .filter((tab): tab is { label: string; href: string; active: boolean } => Boolean(tab.href))
  : [];
const sectionsLabel = Astro.locals.starlightRoute.locale === 'zh-cn' ? '文档分区' : 'Documentation sections';
---

<div class="docs-header" data-docs-header>
  <div class="header">
    <div class="title-wrapper sl-flex">
      <SiteTitle />
    </div>
    <div class="sl-flex print:hidden header-search">
      {shouldRenderSearch && <Search />}
    </div>
    <div class="sl-flex print:hidden right-group">
      <div class="header-version">
        <VersionSelector compact />
      </div>
      <div class="sl-hidden md:sl-flex social-icons">
        <SocialIcons />
      </div>
      <div class="sl-hidden md:sl-flex header-selects">
        <ThemeSelect />
        <LanguageSelect />
      </div>
    </div>
  </div>

  {
    tabs.length > 0 && (
      <nav class="header-tabs" aria-label={sectionsLabel}>
        <div class="header-tabs__inner">
          <ul>
            {tabs.map((tab) => (
              <li>
                <a href={tab.href} aria-current={tab.active ? 'page' : undefined}>
                  {tab.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    )
  }

  <VersionBanner />
</div>

<script>
  type HeaderWindow = Window & {
    __carinaHeaderCleanup__?: () => void;
    __carinaHeaderBootBound__?: boolean;
  };
  const headerWindow = window as HeaderWindow;

  /** Sticky offset + keep active section chip in view on mobile. */
  function syncHeaderOffset() {
    const header = document.querySelector<HTMLElement>('header.header');
    if (!header) return;
    const h = header.getBoundingClientRect().height;
    document.documentElement.style.setProperty('--sl-nav-height', `${h}px`);
    document.documentElement.style.setProperty('--docs-nav-height', `${h}px`);
    document.documentElement.style.setProperty(
      '--docs-anchor-offset',
      `calc(${h}px + 1rem)`,
    );
  }

  function scrollActiveTabIntoView() {
    const active = document.querySelector<HTMLElement>(
      '.header-tabs a[aria-current="page"]',
    );
    const scroller = active?.closest<HTMLElement>('.header-tabs__inner');
    if (!active || !scroller) return;
    const item = active.getBoundingClientRect();
    const rail = scroller.getBoundingClientRect();
    if (item.left >= rail.left && item.right <= rail.right) return;
    active.scrollIntoView({
      inline: 'nearest',
      block: 'nearest',
      behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
    });
  }

  function boot() {
    const root = document.querySelector<HTMLElement>('[data-docs-header]');
    if (!root || root.dataset.runtimeReady === '1') return;
    root.dataset.runtimeReady = '1';
    headerWindow.__carinaHeaderCleanup__?.();
    syncHeaderOffset();
    scrollActiveTabIntoView();
    const banner = document.querySelector('[data-version-banner]');
    const observer = banner ? new MutationObserver(syncHeaderOffset) : null;
    observer?.observe(banner!, { attributes: true, attributeFilter: ['hidden'] });
    window.addEventListener('resize', syncHeaderOffset, { passive: true });
    headerWindow.__carinaHeaderCleanup__ = () => {
      observer?.disconnect();
      window.removeEventListener('resize', syncHeaderOffset);
    };
  }

  boot();
  if (!headerWindow.__carinaHeaderBootBound__) {
    headerWindow.__carinaHeaderBootBound__ = true;
    document.addEventListener('astro:page-load', boot);
  }
</script>

<style>
  .docs-header {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .docs-header > .header {
    display: flex;
    gap: var(--sl-nav-gap, 1rem);
    justify-content: space-between;
    align-items: center;
    height: var(--docs-nav-row-height, 3.5rem);
    padding-inline: 0;
  }

  .title-wrapper {
    overflow: clip;
    padding: 0.25rem;
    margin: -0.25rem;
    min-width: 0;
  }

  .header-search {
    flex: 1;
    justify-content: center;
    min-width: 0;
  }

  .right-group {
    gap: 0.5rem;
    align-items: center;
    flex-shrink: 0;
  }

  .header-version {
    display: flex;
    align-items: center;
  }

  .header-selects {
    gap: 0.25rem;
    align-items: center;
  }

  .social-icons {
    gap: 0.75rem;
    align-items: center;
  }

  .social-icons::after {
    content: '';
    height: 1.25rem;
    border-inline-end: 1px solid var(--docs-border-subtle);
    margin-inline-start: 0.15rem;
  }

  @media (min-width: 50rem) {
    /*
     * Symmetric 1fr | search | 1fr grid so the search pill centers on the
     * VIEWPORT. The previous sidebar-derived first column made the middle
     * cell center in leftover space — visibly left of center because the
     * right control group is much wider than the logo.
     */
    .docs-header > .header {
      display: grid;
      grid-template-columns: 1fr minmax(0, calc(var(--docs-search-max, 28rem) + 2rem)) 1fr;
      align-content: center;
    }

    .title-wrapper {
      justify-self: start;
    }

    .right-group {
      justify-self: end;
    }
  }

  .header-tabs {
    border-top: 1px solid var(--docs-border-subtle);
    background: color-mix(in srgb, var(--docs-bg) 40%, transparent);
  }

  .header-tabs__inner {
    overflow-x: auto;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-inline: var(--sl-nav-pad-x, 1rem);
    /* Fade hint that more sections exist on small screens */
    mask-image: linear-gradient(
      90deg,
      #000 0%,
      #000 calc(100% - 1.75rem),
      transparent 100%
    );
  }

  @media (min-width: 50rem) {
    .header-tabs__inner {
      mask-image: none;
    }
  }

  .header-tabs__inner::-webkit-scrollbar {
    display: none;
  }

  .header-tabs ul {
    display: flex;
    align-items: stretch;
    gap: 0.15rem;
    margin: 0;
    /* Cancel the first link's own padding so tab text sits on the same
       text rhythm as the sidebar rows (nav pad + 0.65rem) */
    margin-inline-start: -0.65rem;
    padding: 0;
    padding-inline-end: 1.5rem;
    list-style: none;
    min-height: var(--docs-tabs-height);
  }

  .header-tabs a {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: var(--docs-tabs-height);
    padding: 0 0.65rem;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1;
    color: var(--docs-fg-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--docs-transition);
  }

  .header-tabs a::after {
    content: '';
    position: absolute;
    inset-inline: 0.55rem;
    bottom: 0;
    height: 2px;
    border-radius: 1px 1px 0 0;
    background: transparent;
  }

  .header-tabs a:hover {
    color: var(--docs-fg);
  }

  .header-tabs a[aria-current='page'] {
    color: var(--docs-fg);
    font-weight: 600;
  }

  .header-tabs a[aria-current='page']::after {
    background: var(--docs-accent);
  }

  /* Mobile: slightly denser chips, scroll into view via CSS snap */
  @media (max-width: 49.999rem) {
    .header-tabs ul {
      margin-inline-start: 0;
      gap: 0.25rem;
      scroll-snap-type: x proximity;
    }

    .header-tabs li {
      scroll-snap-align: start;
    }

    .header-tabs a {
      height: 2.125rem;
      padding: 0 0.7rem;
      font-size: 0.78rem;
      border-radius: var(--docs-radius-full);
      border: 1px solid transparent;
    }

    .header-tabs a[aria-current='page'] {
      border-color: color-mix(in srgb, var(--docs-accent) 35%, var(--docs-border-subtle));
      background: color-mix(in srgb, var(--docs-accent) 8%, transparent);
    }

    .header-tabs a[aria-current='page']::after {
      display: none;
    }
  }
</style>
