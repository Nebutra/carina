---
/**
 * Header — Starlight brand row + Mintlify-style section tabs.
 * Tabs = top-level sidebar groups (href = first leaf link).
 * Hidden below md; mobile drawer already exposes groups.
 */
import Default from '@astrojs/starlight/components/Header.astro';

type SidebarEntry =
  | { type: 'link'; href: string; label: string; isCurrent: boolean }
  | { type: 'group'; label: string; entries: SidebarEntry[] };

const { sidebar } = Astro.locals.starlightRoute;
const hasSidebar = Astro.locals.starlightRoute.hasSidebar;

function firstLink(entries: SidebarEntry[]): string | undefined {
  for (const e of entries) {
    if (e.type === 'link') return e.href;
    const nested = firstLink(e.entries);
    if (nested) return nested;
  }
  return undefined;
}

function containsCurrent(entries: SidebarEntry[]): boolean {
  return entries.some((e) =>
    e.type === 'link' ? e.isCurrent : containsCurrent(e.entries),
  );
}

const tabs = hasSidebar
  ? (sidebar as SidebarEntry[])
      .filter((e): e is Extract<SidebarEntry, { type: 'group' }> => e.type === 'group')
      .map((group) => ({
        label: group.label,
        href: firstLink(group.entries),
        active: containsCurrent(group.entries),
      }))
      .filter((tab): tab is { label: string; href: string; active: boolean } => Boolean(tab.href))
  : [];
---

<div class="docs-header">
  <Default><slot /></Default>
  {
    tabs.length > 0 && (
      <nav class="header-tabs sl-hidden md:sl-block" aria-label="Sections">
        <div class="header-tabs__inner">
          <ul>
            {tabs.map((tab) => (
              <li>
                <a href={tab.href} aria-current={tab.active ? 'page' : undefined}>
                  {tab.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    )
  }
</div>

<style>
  .docs-header {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .header-tabs {
    border-top: 1px solid var(--docs-border-subtle);
    background: color-mix(in srgb, var(--docs-bg) 40%, transparent);
  }

  .header-tabs__inner {
    overflow-x: auto;
    scrollbar-width: none;
    /* Align with Starlight header horizontal padding */
    padding-inline: var(--sl-nav-pad-x, 1rem);
  }

  .header-tabs__inner::-webkit-scrollbar {
    display: none;
  }

  .header-tabs ul {
    display: flex;
    align-items: stretch;
    gap: 0.15rem;
    margin: 0;
    padding: 0;
    list-style: none;
    min-height: var(--docs-tabs-height);
  }

  .header-tabs a {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: var(--docs-tabs-height);
    padding: 0 0.85rem;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1;
    color: var(--docs-fg-muted);
    text-decoration: none;
    white-space: nowrap;
    border-radius: var(--docs-radius-sm) var(--docs-radius-sm) 0 0;
    transition:
      color var(--docs-transition),
      background-color var(--docs-transition);
  }

  .header-tabs a::after {
    content: '';
    position: absolute;
    inset-inline: 0.55rem;
    bottom: 0;
    height: 2px;
    border-radius: 1px 1px 0 0;
    background: transparent;
    transition: background-color var(--docs-transition);
  }

  .header-tabs a:hover {
    color: var(--docs-fg);
    background: color-mix(in srgb, var(--docs-bg-raised) 50%, transparent);
  }

  .header-tabs a[aria-current='page'] {
    color: var(--docs-fg);
    font-weight: 600;
  }

  .header-tabs a[aria-current='page']::after {
    background: var(--docs-accent);
  }

  .header-tabs a:focus-visible {
    outline: 2px solid var(--docs-focus);
    outline-offset: -2px;
  }
</style>
