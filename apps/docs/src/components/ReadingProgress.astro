---
/**
 * Top hairline reading progress — CSS + light JS, no deps.
 */
---

<div class="docs-progress" data-reading-progress aria-hidden="true"></div>

<script>
  type ProgressWindow = Window & {
    __carinaProgressCleanup__?: () => void;
    __carinaProgressBootBound__?: boolean;
  };
  const progressWindow = window as ProgressWindow;

  function boot() {
    const el = document.querySelector<HTMLElement>('[data-reading-progress]');
    if (!el || el.dataset.ready === '1') return;
    el.dataset.ready = '1';
    progressWindow.__carinaProgressCleanup__?.();

    const onScroll = () => {
      const doc = document.documentElement;
      const max = doc.scrollHeight - doc.clientHeight;
      const p = max > 0 ? doc.scrollTop / max : 0;
      el.style.transform = `scaleX(${Math.min(1, Math.max(0, p))})`;
    };

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    progressWindow.__carinaProgressCleanup__ = () => {
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('resize', onScroll);
    };
  }

  boot();
  if (!progressWindow.__carinaProgressBootBound__) {
    progressWindow.__carinaProgressBootBound__ = true;
    document.addEventListener('astro:page-load', boot);
  }
</script>
