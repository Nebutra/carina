---
/**
 * Mintlify-style page export control.
 *
 * Primary: "Copy page" (Markdown for LLMs).
 * Chevron opens: copy again · view as Markdown.
 * No separate "Edit" chrome — that is a different, open-source-only pattern.
 */
const entry = Astro.locals.starlightRoute.entry;
const title = entry.data.title ?? 'Carina';
const id = String(entry.id || '')
  .replace(/^\//, '')
  .replace(/\.mdx?$/, '');
const menuId = `page-actions-menu-${id.replace(/[^a-zA-Z0-9_-]/g, '-') || 'page'}`;
const isZh = Astro.locals.starlightRoute.locale === 'zh-cn';
const t = isZh
  ? {
      copyPage: '复制页面',
      copyAria: '以 Markdown 格式复制页面',
      copied: '已复制',
      more: '更多复制选项',
      copyDesc: '复制适合模型读取的 Markdown',
      view: '查看 Markdown',
      viewDesc: '以纯文本查看本页',
      openUrl: '打开 Markdown 地址',
      openUrlDesc: '打开机器可读的 .md 导出',
      openChatGpt: '在 ChatGPT 中打开',
      openChatGptDesc: '让 ChatGPT 阅读本页',
      openClaude: '在 Claude 中打开',
      openClaudeDesc: '让 Claude 阅读本页',
      markdown: 'Markdown',
      copy: '复制',
      close: '关闭',
      source: '来源',
      readPrompt: '阅读此页面并回答相关问题：',
    }
  : {
      copyPage: 'Copy page',
      copyAria: 'Copy page as Markdown',
      copied: 'Copied',
      more: 'More copy options',
      copyDesc: 'Copy Markdown formatted for models',
      view: 'View as Markdown',
      viewDesc: 'View this page as plain text',
      openUrl: 'Open Markdown URL',
      openUrlDesc: 'Open the machine-readable .md export',
      openChatGpt: 'Open in ChatGPT',
      openChatGptDesc: 'Let ChatGPT read this page',
      openClaude: 'Open in Claude',
      openClaudeDesc: 'Let Claude read this page',
      markdown: 'Markdown',
      copy: 'Copy',
      close: 'Close',
      source: 'Source',
      readPrompt: 'Read this page and answer questions about it:',
    };
---

<div
  class="page-actions"
  data-page-actions
  data-page-title={title}
  data-copied-label={t.copied}
  data-source-label={t.source}
  data-read-prompt={t.readPrompt}
>
  <div class="page-actions__combo">
    <button
      type="button"
      class="page-actions__trigger"
      data-copy-page
      aria-label={t.copyAria}
    >
      <span class="page-actions__icon" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="5.5" y="5.5" width="8" height="8" rx="1.5"></rect>
          <path d="M10.5 5.5V4A1.5 1.5 0 0 0 9 2.5H4A1.5 1.5 0 0 0 2.5 4v5A1.5 1.5 0 0 0 4 10.5h1.5"></path>
        </svg>
      </span>
      <span class="page-actions__label" data-copy-label>{t.copyPage}</span>
    </button>
    <button
      type="button"
      class="page-actions__chevron"
      data-page-menu-toggle
      aria-expanded="false"
      aria-haspopup="menu"
      aria-controls={menuId}
      aria-label={t.more}
    >
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
        <path d="M4 6.5 8 10.5 12 6.5" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
  </div>

  <div class="page-actions__menu" id={menuId} role="menu" hidden data-page-menu>
    <button type="button" class="page-actions__item" role="menuitem" tabindex="-1" data-action="copy-md">
      <span class="page-actions__item-icon" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="5.5" y="5.5" width="8" height="8" rx="1.5"></rect>
          <path d="M10.5 5.5V4A1.5 1.5 0 0 0 9 2.5H4A1.5 1.5 0 0 0 2.5 4v5A1.5 1.5 0 0 0 4 10.5h1.5"></path>
        </svg>
      </span>
      <span class="page-actions__item-text">
        <span class="page-actions__item-title">{t.copyPage}</span>
        <span class="page-actions__item-desc">{t.copyDesc}</span>
      </span>
    </button>

    <button type="button" class="page-actions__item" role="menuitem" tabindex="-1" data-action="view-md">
      <span class="page-actions__item-icon" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 3.5h7.5L13 6v6.5H3v-9Z" stroke-linejoin="round"></path>
          <path d="M10.5 3.5V6H13" stroke-linejoin="round"></path>
        </svg>
      </span>
      <span class="page-actions__item-text">
        <span class="page-actions__item-title">{t.view}</span>
        <span class="page-actions__item-desc">{t.viewDesc}</span>
      </span>
    </button>

    <a
      class="page-actions__item"
      role="menuitem"
      tabindex="-1"
      data-action="open-md"
      href="index.md"
      target="_blank"
      rel="noopener"
    >
      <span class="page-actions__item-icon" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 3.5H3.5v9h9V10" stroke-linejoin="round"></path>
          <path d="M9 3.5h3.5V7" stroke-linecap="round"></path>
          <path d="M8 8.5 12.5 4" stroke-linecap="round"></path>
        </svg>
      </span>
      <span class="page-actions__item-text">
        <span class="page-actions__item-title">{t.openUrl}</span>
        <span class="page-actions__item-desc">{t.openUrlDesc}</span>
      </span>
    </a>

    <a
      class="page-actions__item"
      role="menuitem"
      tabindex="-1"
      data-action="open-chatgpt"
      href="https://chatgpt.com/"
      target="_blank"
      rel="noopener"
    >
      <span class="page-actions__item-icon" aria-hidden="true">
        <img class="page-actions__brand-icon page-actions__brand-icon--openai" src="/brands/openai-blossom.svg" alt="" width="16" height="16" />
      </span>
      <span class="page-actions__item-text">
        <span class="page-actions__item-title">{t.openChatGpt}</span>
        <span class="page-actions__item-desc">{t.openChatGptDesc}</span>
      </span>
    </a>

    <a
      class="page-actions__item"
      role="menuitem"
      tabindex="-1"
      data-action="open-claude"
      href="https://claude.ai/new"
      target="_blank"
      rel="noopener"
    >
      <span class="page-actions__item-icon" aria-hidden="true">
        <img class="page-actions__brand-icon" src="/brands/claude-icon.svg" alt="" width="16" height="16" />
      </span>
      <span class="page-actions__item-text">
        <span class="page-actions__item-title">{t.openClaude}</span>
        <span class="page-actions__item-desc">{t.openClaudeDesc}</span>
      </span>
    </a>

  </div>
</div>

<dialog class="page-md-dialog" data-page-md-dialog aria-labelledby="page-md-dialog-title">
  <div class="page-md-dialog__chrome">
    <p class="page-md-dialog__title" id="page-md-dialog-title">{t.markdown}</p>
    <div class="page-md-dialog__actions">
      <button type="button" class="page-md-dialog__btn" data-page-md-copy data-copied-label={t.copied}>{t.copy}</button>
      <button type="button" class="page-md-dialog__btn" data-page-md-close>{t.close}</button>
    </div>
  </div>
  <pre class="page-md-dialog__pre" data-page-md-body tabindex="0"></pre>
</dialog>

<script>
  function articleRoot(): Element | null {
    return (
      document.querySelector('.sl-markdown-content') ||
      document.querySelector('main .content-panel .sl-container')
    );
  }

  /** Lightweight DOM → Markdown for LLM paste. */
  function pageToMarkdown(pageTitle: string, sourceLabel = 'Source'): string {
    const root = articleRoot();
    if (!root) return `# ${pageTitle}\n\n${sourceLabel}: ${location.href}\n`;

    const blocks: string[] = [];
    const push = (s: string) => {
      if (s && s.trim()) blocks.push(s.trimEnd());
    };

    const walk = (node: Element) => {
      if (node.nodeType === Node.TEXT_NODE) return;
      if (!(node instanceof HTMLElement)) return;
      if (
        node.matches(
          '.page-actions, .docs-breadcrumb, .page-title-meta, script, style, .sl-anchor-link',
        )
      ) {
        return;
      }

      const tag = node.tagName.toLowerCase();
      if (/^h[1-6]$/.test(tag)) {
        push(`${'#'.repeat(Number(tag[1]))} ${node.innerText.trim()}`);
        return;
      }
      if (tag === 'p') {
        push(node.innerText.trim());
        return;
      }
      if (tag === 'li') {
        push(`- ${node.innerText.trim()}`);
        return;
      }
      if (tag === 'pre') {
        const lang = node.getAttribute('data-language') || '';
        push('```' + lang + '\n' + node.innerText.replace(/\n$/, '') + '\n```');
        return;
      }
      if (tag === 'blockquote') {
        push(
          node.innerText
            .trim()
            .split('\n')
            .map((l) => `> ${l}`)
            .join('\n'),
        );
        return;
      }
      if (tag === 'table') {
        push(node.innerText.trim());
        return;
      }
      if (tag === 'hr') {
        push('---');
        return;
      }
      if (
        ['ul', 'ol', 'div', 'section', 'article', 'aside', 'details', 'figure'].includes(tag) ||
        node === root
      ) {
        [...node.children].forEach(walk);
      }
    };

    [...root.children].forEach(walk);
    return [`# ${pageTitle}`, '', blocks.join('\n\n'), '', `${sourceLabel}: ${location.href}`].join('\n');
  }

  function flashCopied(labelEl: Element | null, host: Element | null, copiedLabel: string) {
    if (!labelEl) return;
    const prev = labelEl.textContent;
    labelEl.textContent = copiedLabel;
    host?.classList.add('is-copied');
    window.setTimeout(() => {
      labelEl.textContent = prev ?? '';
      host?.classList.remove('is-copied');
    }, 1400);
  }

  async function copyMarkdown(root: HTMLElement) {
    const title = root.dataset.pageTitle || document.title;
    await navigator.clipboard.writeText(pageToMarkdown(title, root.dataset.sourceLabel));
    flashCopied(
      root.querySelector('[data-copy-label]'),
      root.querySelector('.page-actions__combo'),
      root.dataset.copiedLabel || 'Copied',
    );
  }

  type PageActionsWindow = Window & {
    __carinaPageActionsCleanup__?: () => void;
    __carinaPageActionsBootBound__?: boolean;
  };
  const pageActionsWindow = window as PageActionsWindow;

  function initPageActions(root: Element) {
    if (!(root instanceof HTMLElement) || root.dataset.ready === '1') return;
    root.dataset.ready = '1';
    pageActionsWindow.__carinaPageActionsCleanup__?.();

    const combo = root.querySelector('.page-actions__combo');
    const toggle = root.querySelector<HTMLButtonElement>('[data-page-menu-toggle]');
    const menu = root.querySelector<HTMLElement>('[data-page-menu]');
    const copyMain = root.querySelector('[data-copy-page]');
    const dialog = document.querySelector('[data-page-md-dialog]');
    const dialogBody = dialog?.querySelector('[data-page-md-body]');
    const dialogCopy = dialog?.querySelector('[data-page-md-copy]');
    const dialogClose = dialog?.querySelector('[data-page-md-close]');

    const menuItems = () => Array.from(menu?.querySelectorAll<HTMLElement>('[role="menuitem"]') || []);
    const closeMenu = (restoreFocus = false) => {
      if (!menu || !toggle) return;
      menu.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
      combo?.classList.remove('is-open');
      if (restoreFocus) toggle.focus();
    };
    const openMenu = (focus: 'first' | 'last' | false = 'first') => {
      if (!menu || !toggle) return;
      menu.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
      combo?.classList.add('is-open');
      if (focus) {
        const items = menuItems();
        (focus === 'first' ? items[0] : items.at(-1))?.focus();
      }
    };

    copyMain?.addEventListener('click', async () => {
      try {
        await copyMarkdown(root);
        closeMenu();
      } catch {
        /* clipboard blocked */
      }
    });

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (menu?.hidden) openMenu('first');
      else closeMenu();
    });
    toggle?.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
      e.preventDefault();
      openMenu(e.key === 'ArrowDown' ? 'first' : 'last');
    });
    menu?.addEventListener('keydown', (e) => {
      const items = menuItems();
      const current = items.indexOf(document.activeElement as HTMLElement);
      if (e.key === 'Escape') {
        e.preventDefault();
        closeMenu(true);
        return;
      }
      if (e.key === 'Tab') {
        closeMenu();
        return;
      }
      let next: number | undefined;
      if (e.key === 'ArrowDown') next = (current + 1 + items.length) % items.length;
      if (e.key === 'ArrowUp') next = (current - 1 + items.length) % items.length;
      if (e.key === 'Home') next = 0;
      if (e.key === 'End') next = items.length - 1;
      if (next === undefined || !items.length) return;
      e.preventDefault();
      items[next]?.focus();
    });

    root.querySelector('[data-action="copy-md"]')?.addEventListener('click', async () => {
      try {
        await copyMarkdown(root);
        closeMenu();
      } catch {
        /* ignore */
      }
    });

    root.querySelector('[data-action="view-md"]')?.addEventListener('click', () => {
      const title = root.dataset.pageTitle || document.title;
      if (dialogBody) dialogBody.textContent = pageToMarkdown(title, root.dataset.sourceLabel);
      closeMenu();
      if (dialog instanceof HTMLDialogElement) {
        dialog.showModal();
        requestAnimationFrame(() => dialogClose instanceof HTMLElement && dialogClose.focus());
      }
    });

    // Open-in-AI deep links — absolute .md export URL (same target as open-md).
    const mdUrl = new URL('index.md', location.href).href;
    const aiPayload = encodeURIComponent(`${root.dataset.readPrompt || 'Read this page:'} ${mdUrl}`);
    root
      .querySelector('[data-action="open-chatgpt"]')
      ?.setAttribute('href', `https://chatgpt.com/?hints=search&q=${aiPayload}`);
    root
      .querySelector('[data-action="open-claude"]')
      ?.setAttribute('href', `https://claude.ai/new?q=${aiPayload}`);
    root.querySelectorAll('[data-action="open-chatgpt"], [data-action="open-claude"]').forEach((el) => {
      el.addEventListener('click', () => closeMenu());
    });

    dialogCopy?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(dialogBody?.textContent || '');
        const prev = dialogCopy.textContent;
        dialogCopy.textContent =
          dialogCopy instanceof HTMLElement ? dialogCopy.dataset.copiedLabel || 'Copied' : 'Copied';
        window.setTimeout(() => {
          dialogCopy.textContent = prev;
        }, 1200);
      } catch {
        /* ignore */
      }
    });

    dialogClose?.addEventListener('click', () => {
      if (dialog instanceof HTMLDialogElement) dialog.close();
    });
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog && dialog instanceof HTMLDialogElement) dialog.close();
    });

    // Self-cleaning document listeners: the ClientRouter swaps the body on
    // soft navigation, so drop handlers once this root is detached.
    const onDocClick = (e: MouseEvent) => {
      if (!root.isConnected) {
        document.removeEventListener('click', onDocClick);
        return;
      }
      if (!(e.target instanceof Node) || !root.contains(e.target)) closeMenu();
    };
    const onDocKeydown = (e: KeyboardEvent) => {
      if (!root.isConnected) {
        document.removeEventListener('keydown', onDocKeydown);
        return;
      }
      if (e.key === 'Escape' && menu && !menu.hidden) closeMenu(true);
    };
    document.addEventListener('click', onDocClick);
    document.addEventListener('keydown', onDocKeydown);
    pageActionsWindow.__carinaPageActionsCleanup__ = () => {
      document.removeEventListener('click', onDocClick);
      document.removeEventListener('keydown', onDocKeydown);
    };
  }

  function boot() {
    document.querySelectorAll('[data-page-actions]').forEach(initPageActions);
  }
  boot();
  if (!pageActionsWindow.__carinaPageActionsBootBound__) {
    pageActionsWindow.__carinaPageActionsBootBound__ = true;
    document.addEventListener('astro:page-load', boot);
  }
</script>

<style>
  .page-actions {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    margin: 0 0 var(--spacing-3);
    z-index: 5;
  }

  .page-actions__combo {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--docs-border-subtle);
    border-radius: 999px;
    background: color-mix(in srgb, var(--docs-bg-surface) 80%, transparent);
    overflow: hidden;
    transition:
      border-color var(--docs-transition),
      background-color var(--docs-transition);
  }

  .page-actions__combo:hover,
  .page-actions__combo.is-open {
    border-color: var(--docs-border);
    background: var(--docs-bg-surface);
  }

  .page-actions__combo.is-copied {
    border-color: color-mix(in srgb, var(--docs-success) 45%, var(--docs-border-subtle));
  }

  .page-actions__trigger,
  .page-actions__chevron {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-height: 2rem;
    border: 0;
    background: transparent;
    color: var(--docs-fg-muted);
    font-family: var(--docs-font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1;
    cursor: pointer;
    transition: color var(--docs-transition), background-color var(--docs-transition);
  }

  .page-actions__trigger {
    padding: 0 0.55rem 0 0.7rem;
  }

  .page-actions__chevron {
    padding: 0 0.45rem;
    border-inline-start: 1px solid var(--docs-border-subtle);
  }

  .page-actions__trigger:hover,
  .page-actions__chevron:hover,
  .page-actions__trigger:focus-visible,
  .page-actions__chevron:focus-visible {
    color: var(--docs-fg);
    background: color-mix(in srgb, var(--docs-fg) 3.5%, transparent);
  }

  .page-actions__trigger:focus-visible,
  .page-actions__chevron:focus-visible {
    outline: 2px solid var(--docs-focus);
    outline-offset: -2px;
  }

  .page-actions__combo.is-copied .page-actions__label {
    color: var(--docs-success);
  }

  .page-actions__icon {
    display: inline-flex;
    opacity: 0.85;
  }

  .page-actions__menu {
    position: absolute;
    top: calc(100% + 0.35rem);
    inset-inline-end: 0;
    min-width: 16.5rem;
    padding: 0.3rem;
    border: 1px solid var(--docs-border-subtle);
    border-radius: 8px;
    background: var(--docs-bg-surface);
    z-index: 20;
  }

  .page-actions__item {
    appearance: none;
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    width: 100%;
    margin: 0;
    padding: 0.55rem 0.6rem;
    border: 0;
    border-radius: 8px;
    background: transparent;
    color: var(--docs-fg);
    font-family: var(--docs-font-sans);
    text-align: start;
    text-decoration: none;
    cursor: pointer;
    transition: background-color var(--docs-transition);
  }

  a.page-actions__item {
    -webkit-text-fill-color: currentColor;
  }

  .page-actions__item:hover,
  .page-actions__item:focus-visible {
    background: color-mix(in srgb, var(--docs-fg) 4%, transparent);
    outline: none;
  }

  .page-actions__item-icon {
    display: inline-flex;
    margin-top: 0.1rem;
    color: var(--docs-fg-muted);
    flex-shrink: 0;
  }

  .page-actions__brand-icon {
    display: block;
    width: 1rem;
    height: 1rem;
    object-fit: contain;
  }

  :global([data-theme='dark']) .page-actions__brand-icon--openai,
  :global([data-theme='carina-dark']) .page-actions__brand-icon--openai {
    filter: invert(1);
  }

  .page-actions__item-text {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    min-width: 0;
  }

  .page-actions__item-title {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--docs-fg);
    line-height: 1.25;
  }

  .page-actions__item-desc {
    font-size: 0.72rem;
    color: var(--docs-fg-subtle);
    line-height: 1.3;
  }

  .page-md-dialog {
    width: min(40rem, calc(100vw - 2rem));
    max-height: min(70vh, 36rem);
    margin: auto;
    padding: 0;
    border: 1px solid var(--docs-border-subtle);
    border-radius: 8px;
    background: var(--docs-bg-surface);
    color: var(--docs-fg);
  }

  .page-md-dialog::backdrop {
    background: color-mix(in srgb, var(--docs-bg) 55%, transparent);
    backdrop-filter: blur(6px);
  }

  .page-md-dialog__chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.65rem 0.75rem;
    border-bottom: 1px solid var(--docs-border-subtle);
  }

  .page-md-dialog__title {
    margin: 0;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .page-md-dialog__actions {
    display: flex;
    gap: 0.35rem;
  }

  .page-md-dialog__btn {
    appearance: none;
    min-height: 2rem;
    padding: 0 0.6rem;
    border: 1px solid var(--docs-border-subtle);
    border-radius: 999px;
    background: transparent;
    color: var(--docs-fg-muted);
    font-family: var(--docs-font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
  }

  .page-md-dialog__btn:hover {
    color: var(--docs-fg);
    border-color: var(--docs-border);
  }

  .page-md-dialog__pre {
    margin: 0;
    padding: 0.85rem 1rem 1rem;
    max-height: min(56vh, 28rem);
    overflow: auto;
    font-family: var(--docs-font-mono);
    font-size: 0.75rem;
    line-height: 1.55;
    color: var(--docs-fg-muted);
    white-space: pre-wrap;
    word-break: break-word;
  }

  @media (max-width: 39.99rem) {
    .page-actions__trigger,
    .page-actions__chevron,
    .page-md-dialog__btn {
      min-height: 2.75rem;
    }

    .page-actions__item {
      min-height: 2.75rem;
      align-items: center;
    }
  }
</style>
