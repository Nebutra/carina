---
import Default from '@astrojs/starlight/components/Head.astro';
import ReadingProgress from './ReadingProgress.astro';
import DocsAssistant from './DocsAssistant.astro';
import Motion from './Motion.astro';
import DocsChrome from './DocsChrome.astro';
---

<Default {...Astro.props}><slot /></Default>
<link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />
<link rel="alternate" type="text/markdown" title="skill.md" href="/skill.md" />
{/* Early FOUC class before Motion module; safe if JS disabled (class never set). */}
<script is:inline>
  document.documentElement.classList.add('js-motion');
</script>
<Motion />
<DocsChrome />
<ReadingProgress />
<DocsAssistant />
<script is:inline>
  (() => {
    const root = document.documentElement;
    const onScroll = () => {
      // Glass navbar engages after 80px of scroll (SaaS polish brief)
      root.dataset.scrolled = window.scrollY > 80 ? 'true' : 'false';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // Analytics hooks (Plausible / gtag / custom)
    const track = (name, props) => {
      try {
        window.dispatchEvent(new CustomEvent(name, { detail: props }));
        if (window.plausible) window.plausible(name.replace('carina:', ''), { props });
        if (window.gtag) window.gtag('event', name.replace(/[:.]/g, '_'), props || {});
      } catch (_) {}
    };
    window.addEventListener('carina:docs-feedback', (e) => track('carina:docs-feedback', e.detail));
    window.addEventListener('carina:docs-search-zero', (e) => track('carina:docs-search-zero', e.detail));
    window.addEventListener('carina:docs-ai-ask', (e) => track('carina:docs-ai-ask', e.detail));
  })();
</script>
