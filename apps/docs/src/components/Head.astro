---
import Default from '@astrojs/starlight/components/Head.astro';
import ReadingProgress from './ReadingProgress.astro';
import DocsAssistant from './DocsAssistant.astro';
import Motion from './Motion.astro';
import DocsChrome from './DocsChrome.astro';

// Social card — Starlight emits og:title/description/url + twitter:card, but no
// og:image unless configured; we ship a static branded card (public/og-default.png).
const ogImage = new URL('/og-default.png', Astro.site ?? Astro.url).href;
---

<Default {...Astro.props}><slot /></Default>
<link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />
<link rel="alternate" type="text/markdown" title="skill.md" href="/skill.md" />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Carina Documentation" />
<meta name="twitter:image" content={ogImage} />
{/* Early FOUC class before Motion module; safe if JS disabled (class never set). */}
<script is:inline>
  document.documentElement.classList.add('js-motion');
</script>
<Motion />
<DocsChrome />
{/* ✦ Ask-AI button on code frames (dispatches carina:ask-ai; DocsAssistant listens). */}
<script>
  import '../scripts/code-ask-ai.js';
</script>
<ReadingProgress />
<DocsAssistant />
<script is:inline>
  (() => {
    const root = document.documentElement;
    const runtimeKey = '__carinaDocsHeadRuntime__';
    const previous = window[runtimeKey];
    if (previous) {
      previous.onScroll();
      return;
    }
    const onScroll = () => {
      root.dataset.scrolled = window.scrollY > 80 ? 'true' : 'false';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    const track = (name, props) => {
      try {
        if (window.plausible) window.plausible(name.replace('carina:', ''), { props });
        if (window.gtag) window.gtag('event', name.replace(/[:.]/g, '_'), props || {});
      } catch (_) {}
    };
    const onFeedback = (e) => track('carina:docs-feedback', e.detail);
    const onSearchZero = (e) => track('carina:docs-search-zero', e.detail);
    const onAssistantAsk = (e) => track('carina:docs-ai-ask', e.detail);
    window.addEventListener('carina:docs-feedback', onFeedback);
    window.addEventListener('carina:docs-search-zero', onSearchZero);
    window.addEventListener('carina:docs-ai-ask', onAssistantAsk);
    window[runtimeKey] = { onScroll };
  })();
</script>
