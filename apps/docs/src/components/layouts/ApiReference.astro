---
/**
 * ApiReference — Mintlify-style two-column method block.
 *
 *   Left  (default slot): params / results / prose
 *   Right (slot="code"):  sticky request/response samples
 *
 * Method jump links belong in the page TOC / sidebar — not a third column.
 * Page H2 is the method title; do not pass a duplicate title here.
 *
 *   <ApiReference>
 *     <ParamField ...>...</ParamField>
 *     <CodeBlock slot="code" ... />
 *   </ApiReference>
 */
const zh = Astro.locals.starlightRoute.locale === 'zh-cn';
---

<section class="api-ref">
  <div class="api-ref__grid">
    <div class="api-ref__main">
      <slot />
    </div>
    <aside class="api-ref__code" aria-label={zh ? '代码示例' : 'Code samples'}>
      <div class="api-ref__code-sticky">
        <slot name="code" />
      </div>
    </aside>
  </div>
</section>

<style>
  .api-ref {
    margin: 1.25rem 0 2rem;
    container-type: inline-size;
  }

  /*
   * Two tracks only:
   *  - main grows; code has a stable rail
   *  - stacks under ~900px so description never gets crushed
   */
  .api-ref__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  @container (min-width: 54rem) {
    .api-ref__grid {
      grid-template-columns: minmax(0, 1fr) minmax(16rem, 22rem);
      gap: 1.5rem 1.75rem;
    }
  }

  .api-ref__main {
    min-width: 0;
    color: var(--docs-fg-muted);
  }

  /* Section labels (Params / Result) */
  .api-ref__main :global(.api-ref__section-label),
  .api-ref__main :global(> p:first-child),
  .api-ref__main :global(p > strong:only-child) {
    display: block;
  }

  .api-ref__main :global(.api-ref__section-label),
  .api-ref__main :global(> p strong) {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--docs-fg-subtle);
  }

  .api-ref__main :global(> p) {
    margin: 0 0 0.65rem;
  }

  .api-ref__main :global(> p + p) {
    margin-top: 1.35rem;
  }

  /* Param / response field denser stack inside the rail */
  .api-ref__main :global(.param-field) {
    margin: 0;
    padding: 0.7rem 0;
    border: 0;
    border-bottom: 1px solid var(--docs-border-subtle);
    border-radius: 0;
    background: transparent;
  }

  .api-ref__main :global(.param-field:last-child) {
    border-bottom: 0;
  }

  .api-ref__main :global(.response-field) {
    margin: 0;
    padding: 0.65rem 0 0.65rem 0.85rem;
    border-inline-start: 2px solid color-mix(in srgb, var(--docs-accent) 35%, var(--docs-border-subtle));
  }

  .api-ref__main :global(.param-field__body),
  .api-ref__main :global(.response-field__body) {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--docs-fg-muted);
  }

  /* Fallback tables (if MDX still uses them) */
  .api-ref__main :global(table) {
    display: table;
    width: 100%;
    max-width: 100%;
    border-collapse: collapse;
    table-layout: auto;
    overflow: visible;
    font-size: 0.875rem;
  }

  .api-ref__main :global(thead),
  .api-ref__main :global(tbody),
  .api-ref__main :global(tr) {
    display: table-row-group;
    width: auto;
    min-width: 0;
  }

  .api-ref__main :global(tr) {
    display: table-row;
  }

  .api-ref__main :global(th),
  .api-ref__main :global(td) {
    display: table-cell;
    padding: 0.55rem 0.85rem 0.55rem 0;
    border-bottom: 1px solid var(--docs-border-subtle);
    vertical-align: top;
    white-space: normal;
    overflow-wrap: break-word;
    word-break: normal;
  }

  .api-ref__main :global(th) {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--docs-fg-subtle);
    white-space: nowrap;
  }

  .api-ref__main :global(td:first-child),
  .api-ref__main :global(td code) {
    white-space: nowrap;
    font-family: var(--docs-font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--docs-fg);
  }

  .api-ref__main :global(td:nth-child(2)) {
    white-space: nowrap;
    font-family: var(--docs-font-mono);
    font-size: 0.75rem;
    color: var(--docs-accent);
    padding-inline-end: 1rem;
  }

  .api-ref__main :global(td:last-child) {
    width: 100%;
    color: var(--docs-fg-muted);
  }

  .api-ref__code {
    min-width: 0;
  }

  .api-ref__code-sticky {
    position: relative;
  }

  @container (min-width: 54rem) {
    .api-ref__code-sticky {
      position: sticky;
      top: var(--docs-anchor-offset, 5rem);
    }
  }

  /* Code card fills the rail */
  .api-ref__code :global(.code-block),
  .api-ref__code :global(figure) {
    margin: 0;
    max-width: 100%;
  }

  @container (max-width: 53.999rem) {
    .api-ref__code {
      order: 2;
    }
  }
</style>
