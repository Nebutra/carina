---
/**
 * ApiReference — three-column layout for API docs.
 * Left: in-page method nav (slot="nav")
 * Center: prose description (default slot)
 * Right: sticky code samples (slot="code")
 *
 * Use inside MDX:
 *   <ApiReference>
 *     <Fragment slot="nav">...</Fragment>
 *     ...
 *     <Fragment slot="code">...</Fragment>
 *   </ApiReference>
 */
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<section class="api-ref" aria-label={title ?? 'API reference'}>
  {title && <h2 class="api-ref__heading">{title}</h2>}
  <div class="api-ref__grid">
    <nav class="api-ref__nav" aria-label="Methods">
      <slot name="nav" />
    </nav>
    <div class="api-ref__main">
      <slot />
    </div>
    <aside class="api-ref__code" aria-label="Code samples">
      <div class="api-ref__code-sticky">
        <slot name="code" />
      </div>
    </aside>
  </div>
</section>

<style>
  .api-ref {
    margin: var(--spacing-8) 0;
  }

  .api-ref__heading {
    font-size: var(--text-title-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--docs-fg);
    margin: 0 0 var(--spacing-5);
    line-height: var(--leading-title-sm);
  }

  .api-ref__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-6);
  }

  /* nav + params; code stacks below until there's real room for three tracks */
  @media (min-width: 768px) {
    .api-ref__grid {
      grid-template-columns: 10.5rem minmax(0, 1fr);
    }
  }

  /*
   * Three columns only when the content pane is wide enough that the params
   * column won't collapse under sidebar + TOC + code (was crushing tables).
   */
  @media (min-width: 1400px) {
    .api-ref__grid {
      grid-template-columns: 10.5rem minmax(18rem, 1fr) minmax(15rem, 20rem);
      gap: var(--spacing-8);
    }
  }

  .api-ref__nav {
    font-size: var(--text-body-sm);
    color: var(--docs-fg-muted);
    min-width: 0;
  }

  .api-ref__nav :global(ul) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .api-ref__nav :global(a) {
    display: block;
    padding: 0.35rem 0.5rem;
    border-radius: var(--docs-radius-sm);
    color: var(--docs-fg-muted);
    text-decoration: none;
    font-family: var(--docs-font-mono);
    font-size: var(--text-caption);
    transition:
      color var(--docs-transition),
      background-color var(--docs-transition);
  }

  .api-ref__nav :global(a:hover),
  .api-ref__nav :global(a:focus-visible) {
    color: var(--docs-accent);
    background: var(--docs-bg-selected);
  }

  .api-ref__main {
    /* Allow shrink for overflow-x on tables, but never below readable width */
    min-width: 0;
    color: var(--docs-fg-muted);
  }

  .api-ref__main :global(h3) {
    color: var(--docs-fg);
    font-size: var(--text-title-sm);
    margin-top: var(--spacing-6);
  }

  /* Params tables: scroll instead of crushing field names into vertical glyphs */
  .api-ref__main :global(table) {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .api-ref__main :global(thead),
  .api-ref__main :global(tbody),
  .api-ref__main :global(tr) {
    display: table;
    width: max-content;
    min-width: 100%;
    table-layout: auto;
  }

  .api-ref__main :global(th),
  .api-ref__main :global(td) {
    white-space: normal;
    overflow-wrap: break-word;
    word-break: normal;
  }

  .api-ref__main :global(td:first-child),
  .api-ref__main :global(td:nth-child(2)),
  .api-ref__main :global(th),
  .api-ref__main :global(td code) {
    white-space: nowrap;
    overflow-wrap: normal;
    word-break: normal;
  }

  .api-ref__code {
    min-width: 0;
  }

  .api-ref__code-sticky {
    position: sticky;
    top: var(--docs-anchor-offset);
  }

  /* Code sample under params until the true three-column breakpoint */
  @media (max-width: 1399px) {
    .api-ref__code {
      order: 3;
    }
  }
</style>
