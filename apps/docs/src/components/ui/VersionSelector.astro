---
/**
 * Docs version switcher — static channels (0.6.x / next).
 * Preference is stored in localStorage; a site-wide banner reflects the choice.
 */
import versions from '../../data/versions.json';

interface Props {
  /** Compact mode for header chrome */
  compact?: boolean;
}

const { compact = false } = Astro.props;
const list = versions.versions;
const defaultId = versions.default;
---

<div
  class:list={['version-selector', compact && 'version-selector--compact']}
  data-version-root
  data-default-version={defaultId}
>
  {!compact && <label class="version-selector__label" for="docs-version">Version</label>}
  <select
    id="docs-version"
    class="version-selector__select"
    aria-label="Documentation version"
  >
    {
      list.map((v) => (
        <option value={v.id} data-badge={v.badge} data-description={v.description}>
          {v.label}
          {v.badge === 'preview' ? ' (preview)' : ''}
        </option>
      ))
    }
  </select>
</div>

<script>
  const STORAGE_KEY = 'carina-docs-version';

  function applyVersion(id: string) {
    document.documentElement.dataset.docsVersion = id;
    document.querySelectorAll<HTMLSelectElement>('[data-version-root] select').forEach((sel) => {
      if (sel.value !== id) sel.value = id;
    });
    document.querySelectorAll<HTMLElement>('[data-version-banner]').forEach((banner) => {
      const isNext = id === 'next';
      banner.hidden = !isNext;
    });
    // Version-gated content blocks
    document.querySelectorAll<HTMLElement>('[data-version-only]').forEach((el) => {
      const only = el.dataset.versionOnly || '';
      el.hidden = only !== '' && only !== id;
    });
    window.dispatchEvent(
      new CustomEvent('carina:docs-version', { detail: { version: id } }),
    );
  }

  function boot() {
    const stored = localStorage.getItem(STORAGE_KEY);
    const root = document.querySelector<HTMLElement>('[data-version-root]');
    const fallback = root?.dataset.defaultVersion || '0.6.x';
    const initial = stored || fallback;
    applyVersion(initial);

    document.querySelectorAll<HTMLSelectElement>('[data-version-root] select').forEach((sel) => {
      if (sel.dataset.bound === '1') return;
      sel.dataset.bound = '1';
      sel.addEventListener('change', () => {
        localStorage.setItem(STORAGE_KEY, sel.value);
        applyVersion(sel.value);
      });
    });
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .version-selector {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
  }

  .version-selector__label {
    font-size: var(--text-caption);
    color: var(--docs-fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .version-selector__select {
    appearance: none;
    background-color: var(--docs-bg-surface);
    color: var(--docs-fg);
    border: 0;
    border-radius: var(--docs-radius-md);
    padding: 0.3rem 1.7rem 0.3rem 0.6rem;
    font-size: 0.75rem;
    font-family: var(--docs-font-mono);
    line-height: 1.4;
    cursor: pointer;
    box-shadow: none;
    background-color: transparent;
    background-image: linear-gradient(45deg, transparent 50%, var(--docs-fg-muted) 50%),
      linear-gradient(135deg, var(--docs-fg-muted) 50%, transparent 50%);
    background-position:
      calc(100% - 12px) 55%,
      calc(100% - 8px) 55%;
    background-size:
      4px 4px,
      4px 4px;
    background-repeat: no-repeat;
    transition:
      color var(--docs-transition),
      background-color var(--docs-transition);
  }

  .version-selector__select:hover {
    background-color: color-mix(in srgb, var(--docs-fg) 4%, transparent);
  }

  .version-selector__select:focus-visible {
    outline: 2px solid var(--docs-focus);
    outline-offset: 2px;
  }

  .version-selector--compact .version-selector__select {
    padding-block: 0.25rem;
    font-size: 0.7rem;
  }
</style>
