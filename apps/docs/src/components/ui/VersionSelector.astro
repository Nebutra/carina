---
/**
 * Docs version switcher — static channels (0.6.x / next).
 * Preference is stored in localStorage; a site-wide banner reflects the choice.
 */
import versions from '../../data/versions.json';

interface Props {
  /** Compact mode for header chrome */
  compact?: boolean;
}

const { compact = false } = Astro.props;
const list = versions.versions;
const defaultId = versions.default;
const isZh = Astro.url.pathname.startsWith('/zh-cn/');
const label = isZh ? '版本' : 'Version';
const ariaLabel = isZh ? '文档版本' : 'Documentation version';
---

<div
  class:list={['version-selector', compact && 'version-selector--compact']}
  data-version-root
  data-default-version={defaultId}
>
  {!compact && <label class="version-selector__label" for="docs-version">{label}</label>}
  <select
    id="docs-version"
    class="version-selector__select"
    aria-label={ariaLabel}
  >
    {
      list.map((v) => (
        <option value={v.id} data-badge={v.badge} data-description={v.description}>
          {v.label}
          {v.badge === 'preview' ? (isZh ? '（预览）' : ' (preview)') : ''}
        </option>
      ))
    }
  </select>
</div>

<script>
  const STORAGE_KEY = 'carina-docs-version';

  function catalogVersionFromPath() {
    const path = window.location.pathname.replace(/\/+$/, '/');
    if (/\/(?:zh-cn\/)?api\/methods\/next\/$/.test(path)) return 'next';
    if (/\/(?:zh-cn\/)?api\/methods\/$/.test(path)) return '0.6.x';
    return '';
  }

  function catalogPath(id: string) {
    const path = window.location.pathname.replace(/\/+$/, '/');
    const match = path.match(/^(.*\/(?:zh-cn\/)?api\/methods\/)(?:next\/)?$/);
    if (!match) return '';
    return id === 'next' ? `${match[1]}next/` : match[1] || '';
  }

  function applyVersion(id: string) {
    document.documentElement.dataset.docsVersion = id;
    document.querySelectorAll<HTMLSelectElement>('[data-version-root] select').forEach((sel) => {
      if (sel.value !== id) sel.value = id;
    });
    document.querySelectorAll<HTMLElement>('[data-version-banner]').forEach((banner) => {
      const isNext = id === 'next';
      banner.hidden = !isNext;
    });
    // Version-gated content blocks
    document.querySelectorAll<HTMLElement>('[data-version-only]').forEach((el) => {
      const only = el.dataset.versionOnly || '';
      el.hidden = only !== '' && only !== id;
    });
    window.dispatchEvent(
      new CustomEvent('carina:docs-version', { detail: { version: id } }),
    );
  }

  function boot() {
    const root = document.querySelector<HTMLElement>('[data-version-root]');
    const fallback = root?.dataset.defaultVersion || '0.6.x';
    const allowed = new Set(
      [...document.querySelectorAll<HTMLOptionElement>('[data-version-root] option')].map((option) => option.value),
    );
    const fromUrl = new URL(window.location.href).searchParams.get('version');
    const stored = localStorage.getItem(STORAGE_KEY);
    const fromPath = catalogVersionFromPath();
    const initial = fromPath || (fromUrl && allowed.has(fromUrl) && fromUrl) || (stored && allowed.has(stored) && stored) || fallback;
    if (fromPath) localStorage.setItem(STORAGE_KEY, fromPath);
    applyVersion(initial);

    document.querySelectorAll<HTMLSelectElement>('[data-version-root] select').forEach((sel) => {
      if (sel.dataset.bound === '1') return;
      sel.dataset.bound = '1';
      sel.addEventListener('change', () => {
        localStorage.setItem(STORAGE_KEY, sel.value);
        const targetPath = catalogPath(sel.value);
        if (targetPath && targetPath !== window.location.pathname) {
          const url = new URL(window.location.href);
          url.pathname = targetPath;
          url.searchParams.delete('version');
          const targetKey = sel.value === 'next' ? 'next' : '0-6-x';
          url.hash = url.hash.replace(/^#rpc-(?:0-6-x|next)-/, `#rpc-${targetKey}-`);
          window.location.assign(`${url.pathname}${url.search}${url.hash}`);
          return;
        }
        const url = new URL(window.location.href);
        if (sel.value === fallback) url.searchParams.delete('version');
        else url.searchParams.set('version', sel.value);
        history.replaceState(history.state, '', `${url.pathname}${url.search}${url.hash}`);
        applyVersion(sel.value);
      });
    });
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .version-selector {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
  }

  .version-selector__label {
    font-size: var(--text-caption);
    color: var(--docs-fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .version-selector__select {
    -webkit-appearance: none;
    appearance: none;
    color: var(--docs-fg);
    border: 0 !important;
    border-radius: var(--docs-radius-md);
    padding: 0.3rem 1.7rem 0.3rem 0.6rem;
    font-size: 0.75rem;
    font-family: var(--docs-font-mono);
    line-height: 1.4;
    min-height: 2.25rem;
    cursor: pointer;
    box-shadow: none !important;
    outline: none;
    background-color: transparent !important;
    background-image: linear-gradient(45deg, transparent 50%, var(--docs-fg-muted) 50%),
      linear-gradient(135deg, var(--docs-fg-muted) 50%, transparent 50%);
    background-position:
      calc(100% - 12px) 55%,
      calc(100% - 8px) 55%;
    background-size:
      4px 4px,
      4px 4px;
    background-repeat: no-repeat;
    transition:
      color var(--docs-transition),
      background-color var(--docs-transition);
  }

  .version-selector__select:hover {
    background-color: color-mix(in srgb, var(--docs-fg) 4%, transparent) !important;
  }

  .version-selector__select:focus {
    outline: none;
  }

  .version-selector__select:focus-visible {
    outline: 2px solid var(--docs-focus);
    outline-offset: 2px;
  }

  .version-selector--compact .version-selector__select {
    padding-block: 0.3rem;
    font-size: 0.75rem;
  }
</style>
