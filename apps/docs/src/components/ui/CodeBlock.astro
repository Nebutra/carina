---
/**
 * CodeBlock — highlighted mineral code card for Astro/landing/API layouts.
 * MDX fences use Expressive Code + carina-dark; this component uses the same
 * Carina Shiki theme via Astro <Code /> for one-off snippets.
 */
import { Code } from 'astro:components';
import { carinaDark } from '../../themes/carina-code.mjs';

interface Props {
  code: string;
  lang?: string;
  title?: string;
  showLineNumbers?: boolean;
  copyLabel?: string;
  copiedLabel?: string;
}

const {
  code,
  lang = 'bash',
  title,
  showLineNumbers = false,
  copyLabel = 'Copy',
  copiedLabel = 'Copied',
} = Astro.props;

const uid = `code-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class="code-block" data-lang={lang}>
  <div class="code-block__chrome">
    <div class="code-block__meta">
      {title ? <span class="code-block__title">{title}</span> : null}
      <span class="code-block__lang">{lang}</span>
    </div>
    <button
      type="button"
      class="code-block__copy"
      data-copy-target={uid}
      data-copy-text={code}
      data-copy-label={copyLabel}
      data-copied-label={copiedLabel}
      aria-label={copyLabel}
    >
      <span class="code-block__copy-label">{copyLabel}</span>
    </button>
  </div>
  <div class="code-block__body" id={uid}>
    <Code code={code} lang={lang} theme={carinaDark} />
  </div>
</figure>

<script>
  function initCopyButtons() {
    document.querySelectorAll<HTMLButtonElement>('.code-block__copy').forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        const text =
          btn.dataset.copyText ||
          (btn.dataset.copyTarget
            ? document.getElementById(btn.dataset.copyTarget)?.innerText
            : '') ||
          '';
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
          const label = btn.querySelector('.code-block__copy-label');
          if (label) label.textContent = btn.dataset.copiedLabel ?? 'Copied';
          btn.classList.add('is-copied');
          window.setTimeout(() => {
            if (label) label.textContent = btn.dataset.copyLabel ?? 'Copy';
            btn.classList.remove('is-copied');
          }, 1600);
        } catch {
          /* clipboard may be blocked; silent fail */
        }
      });
    });
  }

  initCopyButtons();
  document.addEventListener('astro:page-load', initCopyButtons);
</script>

<style>
  /*
   * Code cards are ALWAYS dark (matches Expressive Code / Mintlify), so all
   * chrome reads from dark primitives, not theme-switching semantic tokens.
   */
  .code-block {
    margin: var(--spacing-6) 0;
    border: 1px solid var(--polish-code-border, var(--carina-border-subtle));
    border-radius: 8px;
    background: var(--polish-code-bg, var(--carina-surface));
    overflow: hidden;
    box-shadow: inset 0 1px 0 color-mix(in srgb, #f3f0e8 5%, transparent);
    transition: border-color var(--docs-transition);
  }

  .code-block:hover {
    border-color: color-mix(in srgb, var(--carina-border) 75%, var(--carina-ion-cyan) 25%);
  }

  .code-block__chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-3);
    min-height: 2.375rem;
    padding: 0.35rem 0.65rem 0.35rem 0.75rem;
    border-bottom: 1px solid var(--polish-code-border, var(--carina-border-subtle));
    background: var(--polish-code-chrome, var(--carina-surface-raised));
  }

  .code-block__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .code-block__title {
    color: var(--carina-starlight);
    font-family: var(--docs-font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .code-block__lang {
    font-family: var(--docs-font-mono);
    font-size: 0.6875rem;
    color: var(--polish-code-muted, var(--carina-dust));
    letter-spacing: 0.04em;
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--polish-code-border, var(--carina-border-subtle));
    border-radius: 999px;
    background: color-mix(in srgb, var(--polish-code-bg, #12181a) 70%, transparent);
  }

  .code-block__copy {
    appearance: none;
    border: 1px solid var(--polish-code-border, var(--carina-border-subtle));
    background: transparent;
    color: var(--polish-code-muted, var(--carina-dust));
    border-radius: 6px;
    padding: 0.2rem 0.55rem;
    font-size: 0.6875rem;
    font-weight: 500;
    font-family: var(--docs-font-sans);
    cursor: pointer;
    transition:
      color var(--docs-transition),
      border-color var(--docs-transition),
      background-color var(--docs-transition);
  }

  .code-block__copy:hover {
    color: var(--carina-starlight);
    border-color: var(--carina-border);
    background: color-mix(in srgb, var(--polish-code-bg, #12181a) 70%, transparent);
  }

  .code-block__copy:focus-visible {
    outline: 2px solid var(--docs-focus);
    outline-offset: 2px;
  }

  .code-block__copy.is-copied {
    color: var(--carina-spectral-green, #68d2a3);
    border-color: color-mix(in srgb, var(--carina-spectral-green, #68d2a3) 40%, transparent);
  }

  .code-block__body :global(pre) {
    margin: 0 !important;
    padding: 0.95rem 1.1rem !important;
    border: 0 !important;
    border-radius: 0 !important;
    background: transparent !important;
    overflow-x: auto;
    font-size: 0.8125rem !important;
    line-height: 1.65 !important;
    tab-size: 2;
  }

  .code-block__body :global(pre code) {
    font-family: var(--docs-font-mono) !important;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
  }
</style>
