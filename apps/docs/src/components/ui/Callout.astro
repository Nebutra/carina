---
/**
 * Callout — Note / Tip / Warning / Danger blocks.
 * Complements Starlight asides; useful in custom layouts (landing, API ref).
 */
export type CalloutVariant = 'note' | 'tip' | 'warning' | 'danger' | 'success';

interface Props {
  variant?: CalloutVariant;
  title?: string;
}

const { variant = 'note', title } = Astro.props;

const isZh = Astro.locals.starlightRoute.locale === 'zh-cn';
const defaults: Record<CalloutVariant, string> = isZh
  ? {
      note: '说明',
      tip: '提示',
      warning: '警告',
      danger: '注意',
      success: '成功',
    }
  : {
      note: 'Note',
      tip: 'Tip',
      warning: 'Warning',
      danger: 'Caution',
      success: 'Success',
    };

const resolvedTitle = title ?? defaults[variant];
---

<aside class={`callout callout--${variant}`} role="note">
  <p class="callout__title">
    <svg
      class="callout__icon"
      viewBox="0 0 16 16"
      width="16"
      height="16"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      aria-hidden="true"
    >
      {
        variant === 'success' ? (
          <>
            <circle cx="8" cy="8" r="6.25" />
            <path d="M5.5 8.2 7.2 10l3.3-3.6" stroke-linecap="round" stroke-linejoin="round" />
          </>
        ) : variant === 'warning' || variant === 'danger' ? (
          <>
            <path d="M8 2.2 14.4 13H1.6L8 2.2Z" stroke-linejoin="round" />
            <path d="M8 6.4v3" stroke-linecap="round" />
            <circle cx="8" cy="11.2" r="0.55" fill="currentColor" stroke="none" />
          </>
        ) : (
          <>
            <circle cx="8" cy="8" r="6.25" />
            <path d="M8 7.4v3.4" stroke-linecap="round" />
            <circle cx="8" cy="5.1" r="0.55" fill="currentColor" stroke="none" />
          </>
        )
      }
    </svg>
    {resolvedTitle}
  </p>
  <div class="callout__body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    --callout-accent: var(--docs-info);
    margin: var(--spacing-6) 0;
    padding: var(--spacing-4) var(--spacing-5);
    border-radius: var(--docs-radius-xl);
    border: 1px solid color-mix(in srgb, var(--callout-accent) 32%, transparent);
    background: color-mix(in srgb, var(--callout-accent) 7%, var(--docs-bg-surface));
  }

  .callout--tip {
    --callout-accent: var(--docs-accent);
  }
  .callout--warning {
    --callout-accent: var(--docs-warning);
  }
  .callout--danger {
    --callout-accent: var(--docs-danger);
  }
  .callout--success {
    --callout-accent: var(--docs-success);
  }
  .callout--note {
    --callout-accent: var(--docs-info);
  }

  .callout__title {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 var(--spacing-2);
    font-size: var(--text-body-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--callout-accent);
    letter-spacing: 0;
  }

  .callout__icon {
    flex-shrink: 0;
  }

  .callout__body {
    color: var(--docs-fg-muted);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body-sm);
  }

  .callout__body :global(p) {
    margin: 0;
  }

  .callout__body :global(p + p) {
    margin-top: var(--spacing-2);
  }

  .callout__body :global(a) {
    color: var(--docs-accent);
  }

  .callout__body :global(code) {
    font-family: var(--docs-font-mono);
    font-size: 0.9em;
    background: var(--docs-bg-raised);
    border-radius: var(--docs-radius-xs);
    padding: 0.05em 0.3em;
  }
</style>
