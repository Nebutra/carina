---
/**
 * Doc pages: breadcrumb + page actions + default title.
 * Splash/landing: render nothing (Hero owns hierarchy).
 */
import Default from '@astrojs/starlight/components/PageTitle.astro';
import Breadcrumb from './Breadcrumb.astro';
import PageActions from './PageActions.astro';

const isSplash = Astro.locals.starlightRoute.entry.data.template === 'splash';
---

{
  isSplash ? null : (
    <>
      <div class="page-title-meta">
        <Breadcrumb />
        <PageActions />
      </div>
      <Default />
    </>
  )
}

<style>
  .page-title-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    margin-bottom: 0.15rem;
  }

  .page-title-meta :global(.docs-breadcrumb) {
    margin-bottom: 0;
    flex: 1 1 auto;
    min-width: 0;
  }

  /* Align with Perplexity: action sits top-right of the title block */
  .page-title-meta :global(.page-actions) {
    margin-bottom: 0;
    margin-inline-start: auto;
    flex: 0 0 auto;
  }
</style>

