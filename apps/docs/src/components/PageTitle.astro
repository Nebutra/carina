---
/**
 * Doc pages: breadcrumb + page actions + default title + structured lead
 * (frontmatter `description` rendered under the H1, Mintlify-style).
 * Splash/landing: render nothing (Hero owns hierarchy).
 * Also mounts the content-image lightbox (renders on every doc page).
 */
import Default from '@astrojs/starlight/components/PageTitle.astro';
import Breadcrumb from './Breadcrumb.astro';
import PageActions from './PageActions.astro';

const { entry } = Astro.locals.starlightRoute;
const isSplash = entry.data.template === 'splash';
const description = entry.data.description;
---

{
  isSplash ? null : (
    <>
      <div class="page-title-meta">
        <Breadcrumb />
        <PageActions />
      </div>
      <Default />
      {description && (
        <p class="page-lead" data-page-description>
          {description}
        </p>
      )}
    </>
  )
}

<script>
  import { initLightbox } from '../scripts/docs-lightbox';

  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>

<style>
  .page-title-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    margin-bottom: 0.15rem;
  }

  .page-title-meta :global(.docs-breadcrumb) {
    margin-bottom: 0;
    flex: 1 1 auto;
    min-width: 0;
  }

  /* Align with Perplexity: action sits top-right of the title block */
  .page-title-meta :global(.page-actions) {
    margin-bottom: 0;
    margin-inline-start: auto;
    flex: 0 0 auto;
  }

  /* Structured lead — frontmatter description under the H1 */
  .page-lead {
    margin: 0.6rem 0 0;
    font-size: 1.075rem;
    line-height: 1.6;
    color: var(--docs-fg-muted);
    max-width: 65ch;
    text-wrap: pretty;
  }
</style>
