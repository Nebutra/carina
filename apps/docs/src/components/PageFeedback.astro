---
/**
 * "Was this page helpful?" + negative-path reason chips (Mintlify-style).
 */
const path = Astro.url.pathname;
const isSplash = Astro.locals.starlightRoute.entry.data.template === 'splash';
const isZh = Astro.locals.starlightRoute.locale === 'zh-cn';
const t = isZh
  ? {
      question: '这个页面有帮助吗？',
      yes: '有',
      no: '没有',
      reason: '哪里有问题？',
      skip: '跳过',
      thanks: '感谢反馈。',
      hint: '本次会话中每个页面仅记录一次投票。',
      reasons: [
        { id: 'unclear', label: '表述不清' },
        { id: 'outdated', label: '内容过时' },
        { id: 'missing', label: '信息缺失' },
        { id: 'broken', label: '示例有误' },
      ],
    }
  : {
      question: 'Was this page helpful?',
      yes: 'Yes',
      no: 'No',
      reason: 'What went wrong?',
      skip: 'Skip',
      thanks: 'Thanks for the feedback.',
      hint: 'One vote per page is recorded during this session.',
      reasons: [
        { id: 'unclear', label: 'Unclear' },
        { id: 'outdated', label: 'Outdated' },
        { id: 'missing', label: 'Missing info' },
        { id: 'broken', label: 'Broken example' },
      ],
    };
---

{
  !isSplash && (
    <div class="docs-feedback" data-feedback-path={path}>
      <p class="docs-feedback__q">{t.question}</p>
      <div class="docs-feedback__actions">
        <button type="button" data-feedback="yes" class="docs-feedback__btn">
          {t.yes}
        </button>
        <button type="button" data-feedback="no" class="docs-feedback__btn">
          {t.no}
        </button>
      </div>
      <div class="docs-feedback__reasons" data-feedback-reasons hidden>
        <p class="docs-feedback__reasons-q">{t.reason}</p>
        <div class="docs-feedback__chips">
          {t.reasons.map((r) => (
            <button type="button" class="docs-feedback__chip" data-feedback-reason={r.id}>
              {r.label}
            </button>
          ))}
          <button type="button" class="docs-feedback__chip" data-feedback-reason="skip">
            {t.skip}
          </button>
        </div>
      </div>
      <p class="docs-feedback__thanks" role="status" aria-live="polite" hidden>
        {t.thanks}
      </p>
      <p class="docs-feedback__hint">{t.hint}</p>
    </div>
  )
}

<script>
  function initFeedback(root: Element) {
    if (!(root instanceof HTMLElement) || root.dataset.ready === '1') return;
    root.dataset.ready = '1';
    const path = root.dataset.feedbackPath || location.pathname;
    const key = `docs-feedback:${path}`;
    const thanks = root.querySelector<HTMLElement>('.docs-feedback__thanks');
    const actions = root.querySelector<HTMLElement>('.docs-feedback__actions');
    const reasons = root.querySelector<HTMLElement>('[data-feedback-reasons]');
    const q = root.querySelector<HTMLElement>('.docs-feedback__q');
    const hint = root.querySelector<HTMLElement>('.docs-feedback__hint');

    const showThanks = () => {
      if (thanks) thanks.hidden = false;
      if (actions) actions.hidden = true;
      if (reasons) reasons.hidden = true;
      if (q) q.hidden = true;
      if (hint) hint.hidden = true;
    };

    const emit = (value: string, reason?: string) => {
      try {
        sessionStorage.setItem(key, reason ? `${value}:${reason}` : value);
      } catch {
        /* Storage can be disabled; the vote event is still useful. */
      }
      window.dispatchEvent(
        new CustomEvent('carina:docs-feedback', {
          detail: { path, value, reason, ts: Date.now() },
        }),
      );
      showThanks();
    };

    let previousVote: string | null = null;
    try {
      previousVote = sessionStorage.getItem(key);
    } catch {
      /* Storage can be disabled. */
    }
    if (previousVote) {
      showThanks();
      return;
    }

    root.querySelectorAll<HTMLButtonElement>('[data-feedback]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const value = btn.dataset.feedback || 'yes';
        if (value === 'no' && reasons) {
          actions && (actions.hidden = true);
          reasons.hidden = false;
          return;
        }
        emit(value);
      });
    });

    root.querySelectorAll<HTMLButtonElement>('[data-feedback-reason]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const reason = btn.dataset.feedbackReason || 'skip';
        emit('no', reason === 'skip' ? undefined : reason);
      });
    });
  }

  function boot() {
    document.querySelectorAll('[data-feedback-path]').forEach(initFeedback);
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>

<style>
  .docs-feedback {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-3);
    margin-top: var(--spacing-10);
    padding: var(--spacing-4) var(--spacing-5);
    border: 1px solid var(--docs-border-subtle);
    border-radius: var(--docs-radius-lg);
    background: transparent;
  }

  .docs-feedback__q {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--docs-fg);
  }

  .docs-feedback__actions {
    display: flex;
    gap: 0.4rem;
  }

  .docs-feedback__btn {
    appearance: none;
    border: 1px solid var(--docs-border-subtle);
    background: transparent;
    color: var(--docs-fg-muted);
    font-family: var(--docs-font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    min-height: 2rem;
    padding: 0.35rem 0.85rem;
    border-radius: var(--docs-radius-full);
    cursor: pointer;
    transition:
      color var(--docs-transition),
      border-color var(--docs-transition),
      background-color var(--docs-transition);
  }

  .docs-feedback__btn:hover {
    color: var(--docs-fg);
    border-color: var(--docs-border);
    background: color-mix(in srgb, var(--docs-fg) 3%, transparent);
  }

  .docs-feedback__btn:focus-visible {
    outline: 2px solid var(--docs-focus);
    outline-offset: 2px;
  }

  .docs-feedback__reasons {
    flex-basis: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .docs-feedback__reasons-q {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--docs-fg-muted);
  }

  .docs-feedback__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .docs-feedback__chip {
    appearance: none;
    border: 1px solid var(--docs-border-subtle);
    background: transparent;
    color: var(--docs-fg-muted);
    font-family: var(--docs-font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    min-height: 2rem;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    cursor: pointer;
    transition:
      color 140ms ease,
      border-color 140ms ease,
      background-color 140ms ease;
  }

  .docs-feedback__chip:hover {
    color: var(--docs-fg);
    border-color: color-mix(in srgb, var(--docs-accent) 40%, var(--docs-border));
    background: color-mix(in srgb, var(--docs-accent) 6%, transparent);
  }

  .docs-feedback__thanks {
    margin: 0;
    font-size: 0.875rem;
    color: var(--docs-fg-muted);
  }

  .docs-feedback__hint {
    margin: 0;
    flex-basis: 100%;
    font-size: 0.72rem;
    color: var(--docs-fg-subtle);
  }

  @media (max-width: 39.99rem) {
    .docs-feedback__btn,
    .docs-feedback__chip {
      min-height: 2.75rem;
    }
  }
</style>
