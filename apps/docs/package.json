{
  "name": "@carina/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Carina documentation site — Astro + Starlight",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "sync-brand": "node ./scripts/sync-brand.mjs",
    "sync-protocol": "node ./scripts/sync-protocol.mjs",
    "sync": "pnpm sync-brand && pnpm sync-protocol",
    "typecheck": "astro check && tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.1",
  "dependencies": {
    "@astrojs/starlight": "^0.41.3",
    "@astrojs/starlight-tailwind": "^5.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3"
  }
}
