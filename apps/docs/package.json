{
  "name": "@carina/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Carina documentation site — Astro + Starlight",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "sync-brand": "node ./scripts/sync-brand.mjs",
    "sync-protocol": "node ./scripts/sync-protocol.mjs",
    "generate-ai-surface": "node ./scripts/generate-ai-surface.mjs",
    "sync": "pnpm sync-brand && pnpm sync-protocol && pnpm generate-ai-surface",
    "prebuild": "pnpm generate-ai-surface",
    "typecheck": "astro check && tsc --noEmit",
    "lighthouse": "pnpm build && pnpm dlx @lhci/cli@0.14.0 autorun --config=./lighthouserc.cjs"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.1",
  "dependencies": {
    "@astrojs/starlight": "^0.41.3",
    "@astrojs/starlight-tailwind": "^5.0.0",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@shikijs/twoslash": "3.12.2",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "gsap": "^3.15.0",
    "katex": "0.16.22",
    "mermaid": "11.16.0",
    "rehype-katex": "7.0.1",
    "remark-math": "6.0.0",
    "sharp": "^0.35.3",
    "shiki": "3.12.2",
    "tailwindcss": "^4.3.2",
    "twoslash": "0.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3"
  }
}
